---
import Logo from './Logo.astro';
import { getFeaturedGames } from '../../data/games';
import { getGameDisplayName } from '../../utils/game-display';
import { defaultLocale, type Locale } from '../../i18n/config';
import { pathForLocale } from '../../i18n/routing';
import { t } from '../../i18n/messages';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const featuredGames = getFeaturedGames();
---

<footer class="border-t border-default bg-nav transition-colors duration-300">
  <div class="page-container py-12 md:py-16">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="w-full max-w-[31.5rem]">
          <Logo variant="isologo" fullWidth size="footer" />
        </div>
        <p class="mt-6 max-w-sm text-sm text-secondary leading-relaxed">
          {t('footer.tagline', locale)}
        </p>
      </div>

      <nav aria-labelledby="footer-site-nav">
        <h2 id="footer-site-nav" class="text-sm font-semibold text-primary">
          {t('footer.siteNavTitle', locale)}
        </h2>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href={pathForLocale('/games', locale)} class="cozy-link">{t('footer.browseGames', locale)}</a></li>
          <li><a href={pathForLocale('/articles', locale)} class="cozy-link">{t('footer.readArticles', locale)}</a></li>
          <li><a href={pathForLocale('/cozy-creators', locale)} class="cozy-link">{t('footer.cozyCreators', locale)}</a></li>
          <li><a href={pathForLocale('/about', locale)} class="cozy-link">{t('footer.about', locale)}</a></li>
          <li><a href={pathForLocale('/privacy', locale)} class="cozy-link">{t('footer.privacy', locale)}</a></li>
        </ul>
      </nav>

      <nav aria-labelledby="footer-game-hubs">
        <h2 id="footer-game-hubs" class="text-sm font-semibold text-primary">
          {t('footer.hubsTitle', locale)}
        </h2>
        <ul class="mt-4 space-y-2 text-sm">
          {
            featuredGames.map((game) => (
              <li>
                <a href={pathForLocale(`/${game.slug}`, locale)} class="cozy-link">
                  {t('footer.hubLink', locale, { game: getGameDisplayName(game, 'short') })}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-default pt-8 text-sm text-muted md:flex-row md:items-center md:justify-between">
      <p>&copy; {new Date().getFullYear()} Mochileaf. {t('footer.copyright', locale)}</p>
      <p class="text-xs">{t('footer.disclaimer', locale)}</p>
    </div>
  </div>
</footer>
