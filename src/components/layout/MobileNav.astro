---
import type { NavItem } from '../../types';
import Logo from './Logo.astro';
import Icon from '../ui/Icon.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';

interface Props {
  title?: string;
  items: NavItem[];
}

const { title = 'Menu', items } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-50 border-b border-default bg-nav backdrop-blur-md lg:hidden transition-colors duration-300">
  <div class="flex items-center justify-between gap-4 px-4 py-3">
    <Logo compact />
    <div class="flex items-center gap-2">
      <ThemeToggle />
      <button
        type="button"
        id="mobile-menu-btn"
        class="flex h-10 w-10 items-center justify-center rounded-xl border border-default bg-card text-secondary"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <Icon name="list" size={22} class="menu-open" />
        <Icon name="x" size={22} class="menu-close hidden" />
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-default bg-nav px-4 py-4"
    aria-label={title}
  >
    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted">{title}</p>
    <ul class="space-y-1">
      {
        items.map((item) => {
          const href = item.href.replace(/\/$/, '') || '/';
          const matches = items.filter((nav) => {
            const navHref = nav.href.replace(/\/$/, '') || '/';
            return (
              currentPath === navHref ||
              (navHref !== '/' && currentPath.startsWith(`${navHref}/`))
            );
          });
          const bestMatch = matches.sort(
            (a, b) => (b.href.replace(/\/$/, '') || '/').length - (a.href.replace(/\/$/, '') || '/').length,
          )[0];
          const isActive = (bestMatch?.href.replace(/\/$/, '') || '/') === href;
          return (
            <li>
              <a href={item.href} class:list={['nav-link block', isActive && 'nav-link-active']}>
                {item.icon && <Icon name={item.icon} size={18} class="shrink-0 opacity-80" />}
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = btn?.querySelector('.menu-open');
  const closeIcon = btn?.querySelector('.menu-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    openIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  });
</script>
