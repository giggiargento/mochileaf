---
import type { NavItem } from '../../types';
import Logo from './Logo.astro';
import NavLinks from './NavLinks.astro';
import Icon from '../ui/Icon.astro';
import LocaleToolbar from '../ui/LocaleToolbar.astro';
import { normalizeNavPath } from '../../utils/navigation';
import { pathForLocale, stripLocalePrefix } from '../../i18n/routing';
import { t } from '../../i18n/messages';
import type { Locale } from '../../i18n/config';

interface Props {
  title?: string;
  items: NavItem[];
  backHref?: string;
  backLabel?: string;
}

const {
  title,
  items,
  backHref = '/',
  backLabel,
} = Astro.props;
const locale = (Astro.currentLocale ?? 'en') as Locale;
const resolvedTitle = title ?? t('nav.menu', locale);
const resolvedBackLabel = backLabel ?? t('nav.backHome', locale);
const currentPath = stripLocalePrefix(normalizeNavPath(Astro.url.pathname));
const backPath = normalizeNavPath(backHref);
const showBackLink = backPath !== currentPath;
---

<header class="sticky top-0 z-50 border-b border-default bg-nav backdrop-blur-md lg:hidden transition-colors duration-300">
  <div class="flex items-center justify-between gap-4 px-4 py-3">
    <Logo variant="icon" href={pathForLocale('/', locale)} />
    <div class="flex items-center gap-2">
      <LocaleToolbar />
      <button
        type="button"
        id="mobile-menu-btn"
        class="icon-btn mobile-menu-btn"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <Icon name="list" size={22} />
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="mobile-menu-panel hidden border-t border-default bg-nav px-4 py-4"
    aria-label={resolvedTitle}
  >
    {
      showBackLink && (
        <a
          href={backHref}
          class="mb-4 inline-flex min-h-11 items-center gap-1.5 text-sm text-muted transition-colors hover:text-accent"
        >
          <Icon name="arrow-left" size={16} />
          {resolvedBackLabel}
        </a>
      )
    }
    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted">{title}</p>
    <NavLinks items={items} currentPath={currentPath} />
  </nav>
</header>
