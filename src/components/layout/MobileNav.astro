---
import type { NavItem } from '../../types';
import Logo from './Logo.astro';
import NavLinks from './NavLinks.astro';
import Icon from '../ui/Icon.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';
import { normalizeNavPath } from '../../utils/navigation';

interface Props {
  title?: string;
  items: NavItem[];
  backHref?: string;
  backLabel?: string;
}

const {
  title = 'Menu',
  items,
  backHref = '/',
  backLabel = 'Back to home',
} = Astro.props;
const currentPath = normalizeNavPath(Astro.url.pathname);
const backPath = normalizeNavPath(backHref);
const showBackLink = backPath !== currentPath;
---

<header class="sticky top-0 z-50 border-b border-default bg-nav backdrop-blur-md lg:hidden transition-colors duration-300">
  <div class="flex items-center justify-between gap-4 px-4 py-3">
    <Logo variant="icon" />
    <div class="flex items-center gap-2">
      <ThemeToggle />
      <button
        type="button"
        id="mobile-menu-btn"
        class="mobile-menu-btn flex h-10 w-10 items-center justify-center rounded-xl border border-default bg-card text-secondary transition-colors hover:text-accent hover:border-sage-300"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <Icon name="list" size={22} data-icon="open" />
        <Icon name="x" size={22} data-icon="close" />
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="mobile-menu-panel hidden border-t border-default bg-nav px-4 py-4"
    aria-label={title}
  >
    {
      showBackLink && (
        <a
          href={backHref}
          class="mb-4 inline-flex min-h-11 items-center gap-1.5 text-sm text-muted transition-colors hover:text-accent"
        >
          <Icon name="arrow-left" size={16} />
          {backLabel}
        </a>
      )
    }
    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-muted">{title}</p>
    <NavLinks items={items} currentPath={currentPath} />
  </nav>
</header>
