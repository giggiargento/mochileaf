---
import type { NavItem } from '../../types';
import Logo from './Logo.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';

interface Props {
  title?: string;
  items: NavItem[];
}

const { title = 'Menu', items } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-cream-200/80 bg-cream-50/90 backdrop-blur-md lg:hidden dark:border-ink-700/60 dark:bg-ink-900/90">
  <div class="flex items-center justify-between gap-4 px-4 py-3">
    <Logo compact />
    <div class="flex items-center gap-2">
      <ThemeToggle />
      <button
        type="button"
        id="mobile-menu-btn"
        class="flex h-10 w-10 items-center justify-center rounded-xl border border-cream-200 bg-white/80 text-ink-500 dark:border-ink-700 dark:bg-ink-800/80 dark:text-ink-200"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg class="h-5 w-5 menu-open" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg class="hidden h-5 w-5 menu-close" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-cream-200 bg-cream-50 px-4 py-4 dark:border-ink-700 dark:bg-ink-900"
    aria-label={title}
  >
    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-ink-300 dark:text-ink-400">{title}</p>
    <ul class="space-y-1">
      {
        items.map((item) => {
          const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block rounded-xl px-4 py-3 text-sm font-medium transition-colors',
                  isActive
                    ? 'bg-sage-100 text-sage-500 dark:bg-sage-500/20 dark:text-sage-200'
                    : 'text-ink-500 hover:bg-cream-100 dark:text-ink-200 dark:hover:bg-ink-800',
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = btn?.querySelector('.menu-open');
  const closeIcon = btn?.querySelector('.menu-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    openIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  });
</script>
