---
import Icon from '../ui/Icon.astro';
import CozyImage from '../ui/CozyImage.astro';
import { getBrandAsset } from '../../data/brand-assets';
import {
  brandIsologo,
  brandLogotipo,
  brandLogoDark,
  brandIcon,
  brandIconDark,
  hasBrandIcon,
  brandAlt,
} from '../../utils/brand';

interface Props {
  href?: string;
  /** isologo: compact lockup · wordmark: logotipo · icon: mobile mark */
  variant?: 'isologo' | 'wordmark' | 'icon';
  /** Span full width of parent */
  fullWidth?: boolean;
  /** Taller lockup when fullWidth (footer) */
  size?: 'default' | 'footer';
}

const { href = '/', variant = 'isologo', fullWidth = false, size = 'default' } = Astro.props;

const isIcon = variant === 'icon';
const isWordmark = variant === 'wordmark';

const lightSrc = isIcon
  ? brandIcon
  : isWordmark
    ? brandLogotipo ?? brandIsologo
    : brandIsologo ?? brandLogotipo;

const darkSrc = isIcon ? brandIconDark ?? brandIcon : brandLogoDark;

const lightAsset = getBrandAsset(lightSrc);
const darkAsset = getBrandAsset(darkSrc);

const useImage = isIcon ? hasBrandIcon || Boolean(lightSrc) : Boolean(lightSrc);

/** Keep Astro Image aspect ratio aligned with the source file (isologo is ~square, not 672×120). */
function brandImageDimensions(asset: typeof lightAsset, fallback: { width: number; height: number }) {
  if (asset?.width && asset?.height) {
    return { width: asset.width, height: asset.height };
  }
  return fallback;
}

const lightDimensions = brandImageDimensions(
  lightAsset,
  isIcon
    ? { width: 36, height: 36 }
    : fullWidth
      ? size === 'footer'
        ? { width: 504, height: 504 }
        : { width: 208, height: 56 }
      : isWordmark
        ? { width: 208, height: 48 }
        : { width: 220, height: 44 },
);

const darkDimensions = brandImageDimensions(
  darkAsset,
  lightDimensions,
);

const imgClass = isIcon
  ? 'h-9 w-9 object-contain'
  : fullWidth
    ? size === 'footer'
      ? 'w-full h-auto max-h-[10.5rem] object-contain object-left'
      : 'w-full h-auto min-h-10 object-contain object-left'
    : isWordmark
      ? 'h-12 w-auto max-w-full object-contain object-left'
      : 'h-11 w-auto max-w-[220px] object-contain object-left';

const responsiveWidths =
  fullWidth && size === 'footer' ? [168, 336, 504] : [144, 208, 320];
const responsiveSizes =
  fullWidth && size === 'footer' ? '(min-width: 768px) 31.5rem, 100vw' : undefined;
---

<a
  href={href}
  class:list={[
    'group shrink-0 items-center',
    fullWidth ? 'block w-full' : 'inline-flex',
  ]}
  aria-label="Mochileaf home"
>
  {
    useImage && lightSrc ? (
      <>
        <CozyImage
          src={lightAsset ?? lightSrc}
          alt={brandAlt}
          width={lightDimensions.width}
          height={lightDimensions.height}
          class:list={[imgClass, darkSrc && darkSrc !== lightSrc && 'dark:hidden']}
          widths={responsiveWidths}
          sizes={responsiveSizes}
          loading="eager"
          fetchpriority={fullWidth ? 'high' : undefined}
          quality={88}
        />
        {darkSrc && darkSrc !== lightSrc && (
          <CozyImage
            src={darkAsset ?? darkSrc}
            alt={brandAlt}
            width={darkDimensions.width}
            height={darkDimensions.height}
            class:list={[imgClass, 'hidden dark:block']}
            widths={responsiveWidths}
            sizes={responsiveSizes}
            loading="eager"
            quality={88}
          />
        )}
      </>
    ) : (
      <>
        <span
          class="flex h-9 w-9 items-center justify-center rounded-2xl bg-sage-100 text-accent shadow-soft transition-transform duration-300 group-hover:scale-105"
          aria-hidden="true"
        >
          <Icon name="leaf" size={20} weight="regular" />
        </span>
        {!isIcon && (
          <span class="font-display text-xl font-semibold text-primary">Mochileaf</span>
        )}
      </>
    )
  }
</a>
