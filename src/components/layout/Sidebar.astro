---
import type { NavItem } from '../../types';
import Logo from './Logo.astro';
import NavLinks from './NavLinks.astro';
import Icon from '../ui/Icon.astro';
import { normalizeNavPath } from '../../utils/navigation';
import { hasBrandLogotipo, hasBrandIsologo } from '../../utils/brand';

const hasBrandHeader = hasBrandLogotipo || hasBrandIsologo;

interface Props {
  /** Shown below brand lockup on game hubs (e.g. game name) */
  title?: string;
  items: NavItem[];
  backHref?: string;
  backLabel?: string;
}

const {
  title,
  items,
  backHref = '/',
  backLabel = 'Back to home',
} = Astro.props;

const currentPath = normalizeNavPath(Astro.url.pathname);
const backPath = normalizeNavPath(backHref);
const showBackLink = backPath !== currentPath;
---

<aside
  class="hidden lg:flex lg:w-64 lg:flex-col lg:fixed lg:inset-y-0 lg:left-0 lg:z-40 border-r border-default bg-nav transition-colors duration-300"
  aria-label="Main navigation"
>
  <div class="flex h-full min-w-0 flex-col p-6">
    <div class="mb-8 min-w-0">
      <Logo variant="wordmark" fullWidth />
      {showBackLink && (
        <a
          href={backHref}
          class="mt-5 inline-flex items-center gap-1.5 text-sm text-muted transition-colors hover:text-accent"
        >
          <Icon name="arrow-left" size={16} />
          {backLabel}
        </a>
      )}
      {
        title && (
          <h2
            class:list={[
              'font-display text-lg text-primary truncate',
              hasBrandHeader ? 'mt-5' : 'mt-3',
            ]}
          >
            {title}
          </h2>
        )
      }
    </div>

    <nav class="min-w-0 flex-1 overflow-y-auto">
      <NavLinks items={items} currentPath={currentPath} />
    </nav>

    <div class="mt-auto min-w-0 pt-6 border-t border-default">
      <slot name="footer" />
    </div>
  </div>
</aside>
