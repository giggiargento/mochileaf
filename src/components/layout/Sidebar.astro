---
import type { NavItem } from '../../types';
import Logo from './Logo.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  title?: string;
  subtitle?: string;
  items: NavItem[];
  backHref?: string;
  backLabel?: string;
}

const {
  title = 'Mochileaf',
  subtitle,
  items,
  backHref = '/',
  backLabel = 'Back to home',
} = Astro.props;

const normalizePath = (path: string) => {
  const trimmed = path.replace(/\/$/, '');
  return trimmed === '' ? '/' : trimmed;
};

const currentPath = normalizePath(Astro.url.pathname);
const backPath = normalizePath(backHref);
const showBackLink = backPath !== currentPath;
---

<aside
  class="hidden lg:flex lg:w-64 lg:flex-col lg:fixed lg:inset-y-0 lg:left-0 lg:z-40 border-r border-default bg-nav transition-colors duration-300"
  aria-label="Main navigation"
>
  <div class="flex flex-col h-full p-6">
    <div class="mb-8">
      {showBackLink ? (
        <a
          href={backHref}
          class="mb-4 inline-flex items-center gap-1.5 text-sm text-muted transition-colors hover:text-accent"
        >
          <Icon name="arrow-left" size={16} />
          {backLabel}
        </a>
      ) : (
        <Logo />
      )}
      {subtitle && (
        <p class="mt-3 text-xs font-medium uppercase tracking-widest text-accent">{subtitle}</p>
      )}
      <h2 class="mt-1 font-display text-lg text-primary">{title}</h2>
    </div>

    <nav class="flex-1 space-y-1">
      {
        items.map((item) => {
          const href = item.href.replace(/\/$/, '') || '/';
          const matches = items.filter((nav) => {
            const navHref = nav.href.replace(/\/$/, '') || '/';
            return (
              currentPath === navHref ||
              (navHref !== '/' && currentPath.startsWith(`${navHref}/`))
            );
          });
          const bestMatch = matches.sort(
            (a, b) => (b.href.replace(/\/$/, '') || '/').length - (a.href.replace(/\/$/, '') || '/').length,
          )[0];
          const isActive = (bestMatch?.href.replace(/\/$/, '') || '/') === href;
          return (
            <a
              href={item.href}
              class:list={['nav-link', isActive && 'nav-link-active']}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.icon && <Icon name={item.icon} size={18} class="shrink-0 opacity-80" />}
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="mt-auto pt-6 border-t border-default">
      <slot name="footer" />
    </div>
  </div>
</aside>
