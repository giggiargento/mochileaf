---
import type { NavItem } from '../../types';
import Icon from '../ui/Icon.astro';
import {
  findBestNavMatch,
  isNavItemActive,
  isNavParentActive,
  normalizeNavPath,
} from '../../utils/navigation';

interface Props {
  items: NavItem[];
  currentPath: string;
}

const { items, currentPath } = Astro.props;
const path = normalizeNavPath(currentPath);
const bestMatch = findBestNavMatch(items, path);
---

<ul class="min-w-0 space-y-1" role="list">
  {
    items.map((item) => {
      const hasChildren = Boolean(item.children?.length);
      const parentActive = hasChildren
        ? isNavParentActive(item, path)
        : isNavItemActive(item, bestMatch);

      return (
        <li
          class:list={['nav-group', hasChildren && parentActive && 'nav-group-open']}
        >
          <div class="nav-group-row flex min-w-0 items-stretch">
            <a
              href={item.href}
              class:list={['nav-link min-w-0 flex-1', parentActive && 'nav-link-active']}
              aria-current={!hasChildren && parentActive ? 'page' : undefined}
            >
              {item.icon && <Icon name={item.icon} size={18} class="shrink-0 opacity-80" />}
              <span class="flex-1">{item.label}</span>
            </a>
            {
              hasChildren && (
                <button
                  type="button"
                  class="nav-group-toggle"
                  data-nav-toggle
                  aria-expanded={parentActive ? 'true' : 'false'}
                  aria-label={`${parentActive ? 'Hide' : 'Show'} ${item.label} submenu`}
                >
                  <Icon
                    name="caret-down"
                    size={14}
                    class="nav-group-caret shrink-0 opacity-60"
                    aria-hidden="true"
                  />
                </button>
              )
            }
          </div>
          {
            hasChildren && (
              <ul
                class="nav-sublist nav-sublist-collapsible space-y-0.5"
                role="group"
                aria-label={`${item.label} hubs`}
              >
                {
                  item.children!.map((child) => {
                    const childActive = isNavItemActive(child, bestMatch);
                    return (
                      <li>
                        <a
                          href={child.href}
                          class:list={['nav-link nav-link-sub', childActive && 'nav-link-active']}
                          aria-current={childActive ? 'page' : undefined}
                        >
                          <span class="block truncate">{child.label}</span>
                        </a>
                      </li>
                    );
                  })
                }
              </ul>
            )
          }
        </li>
      );
    })
  }
</ul>
