---
import {
  getAdSenseClient,
  getAdSlot,
  getAdUnitAttrs,
  hasManualAdUnit,
  type AdPlacement,
} from '../../utils/ads';

interface Props {
  slot?: AdPlacement;
  label?: string;
}

const { slot = 'inline', label = 'Advertisement' } = Astro.props;
const client = getAdSenseClient();
const adSlot = getAdSlot(slot);
const showUnit = hasManualAdUnit(slot);
const unitAttrs = getAdUnitAttrs(slot);

const sizeClasses = {
  banner: 'min-h-[90px] md:min-h-[120px]',
  sidebar: 'min-h-[250px] max-w-[300px] mx-auto',
  inline: 'min-h-[90px] md:min-h-[120px]',
  footer: 'min-h-[90px] md:min-h-[120px]',
};
---

{
  showUnit && client && adSlot ? (
    <aside class:list={['ad-slot', sizeClasses[slot]]} data-ad-slot={slot} aria-label={label}>
      <ins
        class="adsbygoogle block w-full"
        style="display:block"
        data-ad-client={client}
        data-ad-slot={adSlot}
        data-ad-format={unitAttrs.format}
        data-full-width-responsive={unitAttrs.fullWidthResponsive ? 'true' : 'false'}
      />
    </aside>
  ) : (
    <aside
      class:list={[
        'flex flex-col items-center justify-center rounded-[var(--radius-card)] border border-dashed border-default bg-muted/50 text-center',
        sizeClasses[slot],
      ]}
      data-ad-slot={slot}
      aria-label={label}
    >
      <span class="text-xs font-medium uppercase tracking-widest text-muted">{label}</span>
      <span class="mt-1 text-sm text-muted">Ad space · AdSense ready</span>
    </aside>
  )
}
