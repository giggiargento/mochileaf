---
import {
  getAdSenseClient,
  getAdSlot,
  getAdUnitAttrs,
  hasManualAdUnit,
  isAdSenseTestMode,
  shouldRenderAdUnits,
  type AdPlacement,
} from '../../utils/ads';

interface Props {
  slot?: AdPlacement;
  label?: string;
}

const { slot = 'inline', label = 'Advertisement' } = Astro.props;
const client = getAdSenseClient();
const adSlot = getAdSlot(slot);
const showUnit = shouldRenderAdUnits() && hasManualAdUnit(slot);
const unitAttrs = getAdUnitAttrs(slot);
const adTest = isAdSenseTestMode();

const variantClass = slot === 'sidebar' ? 'ad-slot--sidebar' : 'ad-slot--horizontal';
---

{
  showUnit && client && adSlot ? (
    <aside
      class:list={['ad-slot', 'ad-slot-frame', variantClass]}
      data-ad-slot={slot}
      aria-label={label}
    >
      <p class="ad-slot-label">{label}</p>
      <div class="ad-slot-inner">
        <ins
          class="adsbygoogle"
          style="display:block"
          data-ad-client={client}
          data-ad-slot={adSlot}
          data-ad-format={unitAttrs.format}
          data-full-width-responsive={unitAttrs.fullWidthResponsive ? 'true' : 'false'}
          {...(adTest ? { 'data-adtest': 'on' } : {})}
        />
      </div>
      <script is:inline>
        (function () {
          var el = document.currentScript && document.currentScript.previousElementSibling;
          var ins = el && el.querySelector('.adsbygoogle');
          if (ins) ins.setAttribute('data-adsense-requested', 'true');
          (adsbygoogle = window.adsbygoogle || []).push({});
        })();
      </script>
    </aside>
  ) : (
    <aside
      class:list={['ad-slot', 'ad-slot-frame', 'ad-slot--placeholder', variantClass]}
      data-ad-slot={slot}
      aria-label={label}
    >
      <span class="text-xs font-medium uppercase tracking-widest text-muted">{label}</span>
      <span class="mt-1 text-sm text-muted">Ad space · AdSense ready</span>
    </aside>
  )
}
