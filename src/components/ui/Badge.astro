---
interface Props {
  variant?: 'default' | 'sage' | 'blossom' | 'mist' | 'lavender' | 'honey';
  size?: 'sm' | 'md';
  class?: string;
}

const { variant = 'default', size = 'sm', class: className } = Astro.props;

const variants = {
  default: 'badge-default',
  sage: 'badge-sage',
  blossom: 'badge-blossom',
  mist: 'badge-mist',
  lavender: 'badge-lavender',
  honey: 'badge-honey',
};

const sizes = {
  sm: 'px-2.5 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm',
};
---

<span class:list={['badge', variants[variant], sizes[size], className]}>
  <slot />
</span>
