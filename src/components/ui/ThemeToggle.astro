---
import Icon from './Icon.astro';
---

<button
  type="button"
  data-theme-toggle
  class="theme-toggle relative flex h-10 w-10 items-center justify-center rounded-full border border-default bg-card text-secondary shadow-soft transition-all duration-300 hover:text-accent hover:border-sage-300 hover:-translate-y-0.5"
  aria-label="Toggle dark mode"
>
  <Icon name="moon" size={20} data-icon="moon" />
  <Icon name="sun" size={20} data-icon="sun" />
</button>
