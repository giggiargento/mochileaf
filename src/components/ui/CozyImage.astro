---
/**
 * Optimized raster images via astro:assets (WebP + responsive widths).
 * Import images in src/assets and pass ImageMetadata — not public/ URL strings.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  quality?: number;
}

const {
  src,
  alt,
  class: className,
  width,
  height,
  widths = [480, 640, 960, 1280, 1920],
  sizes,
  loading = 'lazy',
  fetchpriority,
  quality = 85,
} = Astro.props;
---

<Image
  src={src}
  alt={alt}
  class={className}
  width={width}
  height={height}
  widths={widths}
  sizes={sizes}
  loading={loading}
  fetchpriority={fetchpriority}
  decoding="async"
  quality={quality}
  format="webp"
/>
