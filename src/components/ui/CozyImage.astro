---
/**
 * Optimized raster images via astro:assets when src is ImageMetadata.
 * Public URL strings use a plain img (synced/dynamic content) and opt out of the dev audit.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  quality?: number;
}

const {
  src,
  alt,
  class: className,
  width,
  height,
  widths = [480, 640, 960, 1280, 1920],
  sizes,
  loading = 'lazy',
  fetchpriority,
  quality = 85,
} = Astro.props;

const isAsset = typeof src === 'object' && src !== null && 'src' in src;
---

{
  isAsset ? (
    <Image
      src={src}
      alt={alt}
      class={className}
      width={width}
      height={height}
      widths={widths}
      sizes={sizes}
      loading={loading}
      fetchpriority={fetchpriority}
      decoding="async"
      quality={quality}
      format="webp"
    />
  ) : (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      fetchpriority={fetchpriority}
      decoding="async"
      data-image-component="true"
    />
  )
}
