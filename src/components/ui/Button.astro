---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-[var(--radius-pill)] font-semibold transition-all duration-300 ease-out focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sage-400 hover:-translate-y-0.5 active:translate-y-0';

const variants = {
  primary:
    'bg-sage-500 text-white shadow-soft hover:bg-sage-600',
  secondary:
    'bg-card border border-default text-secondary shadow-soft hover:border-sage-300 hover:text-accent',
  ghost:
    'text-muted hover:bg-nav hover:text-accent',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-2.5 text-sm',
  lg: 'px-8 py-3 text-base',
};

const classes = [base, variants[variant], sizes[size], className].join(' ');
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type="button" class={classes}>
      <slot />
    </button>
  )
}
