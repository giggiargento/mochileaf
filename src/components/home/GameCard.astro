---
import type { Game } from '../../types';
import Badge from '../ui/Badge.astro';

interface Props {
  game: Game;
}

const { game } = Astro.props;
const accentVariants = {
  sage: 'sage' as const,
  blossom: 'blossom' as const,
  mist: 'mist' as const,
  lavender: 'lavender' as const,
  honey: 'honey' as const,
};
---

<a
  href={game.status === 'active' ? `/${game.slug}` : '#games'}
  class:list={[
    'cozy-card group block overflow-hidden',
    game.status === 'coming-soon' && 'opacity-80 cursor-default',
  ]}
  aria-disabled={game.status === 'coming-soon' ? true : undefined}
>
  <div class:list={['aspect-[16/10] bg-gradient-to-br', game.coverGradient]} />
  <div class="p-6">
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-display text-xl text-ink-700 group-hover:text-sage-500 transition-colors dark:text-cream-100 dark:group-hover:text-sage-300">
        {game.name}
      </h3>
      <Badge variant={accentVariants[game.accent]}>
        {game.status === 'coming-soon' ? 'Soon' : 'Hub'}
      </Badge>
    </div>
    <p class="mt-2 text-sm text-ink-400 line-clamp-2 dark:text-ink-300">{game.tagline}</p>
    {
      game.status === 'active' && (
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-sage-500 dark:text-sage-300">
          Enter hub
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </span>
      )
    }
  </div>
</a>
