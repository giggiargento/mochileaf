---
import type { Game } from '../../types';
import Badge from '../ui/Badge.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  game: Game;
}

const { game } = Astro.props;
const accentVariants = {
  sage: 'sage' as const,
  blossom: 'blossom' as const,
  mist: 'mist' as const,
  lavender: 'lavender' as const,
  honey: 'honey' as const,
};
---

<a
  href={game.status === 'active' ? `/${game.slug}` : '/games'}
  class:list={[
    'cozy-card group block overflow-hidden',
    game.status === 'coming-soon' && 'opacity-80 cursor-default',
  ]}
  aria-disabled={game.status === 'coming-soon' ? true : undefined}
>
  <div class:list={['aspect-[16/10] bg-gradient-to-br', game.coverGradient]} />
  <div class="p-6">
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-display text-xl text-primary group-hover:text-accent transition-colors duration-300">
        {game.name}
      </h3>
      <Badge variant={accentVariants[game.accent]}>
        {game.status === 'coming-soon' ? 'Soon' : 'Hub'}
      </Badge>
    </div>
    <p class="mt-2 text-sm text-secondary line-clamp-2">{game.tagline}</p>
    {
      game.status === 'active' && (
        <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
          Enter hub
          <Icon name="arrow-right" size={16} class="transition-transform duration-300 group-hover:translate-x-1" />
        </span>
      )
    }
  </div>
</a>
