---
import type { Game } from '../../types';
import { gameCardImagePath } from '../../utils/game-images';
import { getGameCardAsset } from '../../data/game-assets';
import CozyImage from '../ui/CozyImage.astro';
import { localePath, resolveLocale } from '../../i18n/locale';
import { t } from '../../i18n/messages';
import Badge from '../ui/Badge.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  game: Game;
}

const { game } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const accentVariants = {
  sage: 'sage' as const,
  blossom: 'blossom' as const,
  mist: 'mist' as const,
  lavender: 'lavender' as const,
  honey: 'honey' as const,
};

const cardSrc = getGameCardAsset(game.slug) ?? gameCardImagePath(game.slug);
const cardAlt = `${game.name} — cozy game hub on Mochileaf`;
const hubHref =
  game.status === 'active' ? localePath(`/${game.slug}`, locale) : localePath('/games', locale);
---

<a
  href={hubHref}
  data-astro-reload
  class:list={[
    'cozy-card group flex h-full flex-col overflow-hidden',
    game.status === 'coming-soon' && 'opacity-80 cursor-default',
  ]}
  aria-disabled={game.status === 'coming-soon' ? true : undefined}
>
  <div class="game-card-media relative aspect-[16/10] overflow-hidden">
    {
      cardSrc ? (
        <div
          class="h-full w-full origin-center transition-transform duration-500 ease-out will-change-transform group-hover:scale-105"
        >
          <CozyImage
            src={cardSrc}
            alt={cardAlt}
            width={640}
            height={400}
            class="game-card-image h-full w-full object-cover"
            widths={[480, 640, 960]}
            sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            loading="lazy"
          />
        </div>
      ) : (
        <div
          class:list={[
            'game-card-fallback h-full w-full bg-gradient-to-br',
            game.coverGradient,
          ]}
          aria-hidden="true"
        />
      )
    }
  </div>
  <div class="flex flex-1 flex-col p-6">
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-display text-xl text-primary group-hover:text-accent transition-colors duration-300">
        {game.name}
      </h3>
      <Badge variant={accentVariants[game.accent]}>
        {game.status === 'coming-soon' ? t('gameCard.soon', locale) : t('gameCard.hub', locale)}
      </Badge>
    </div>
    <p class="mt-2 text-sm text-secondary line-clamp-2">{game.tagline}</p>
    {
      game.status === 'active' && (
        <span class="mt-auto inline-flex items-center gap-1.5 pt-4 text-sm font-semibold text-accent">
          {t('gameCard.enterHub', locale)}
          <Icon name="arrow-right" size={16} class="transition-transform duration-300 group-hover:translate-x-1" />
        </span>
      )
    }
  </div>
</a>
