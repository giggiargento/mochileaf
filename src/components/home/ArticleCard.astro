---
import type { Article } from '../../types';
import Badge from '../ui/Badge.astro';
import { getGame } from '../../data/games';
import { getArticleHref } from '../../utils/article-routes';
import { getGameDisplayName } from '../../utils/game-display';

interface Props {
  article: Article;
  /** Home trending column: 2-line excerpt + ellipsis, card height unchanged */
  compact?: boolean;
}

const { article, compact = false } = Astro.props;
const game = article.gameSlug ? getGame(article.gameSlug) : undefined;

const categoryVariants: Record<Article['category'], 'default' | 'sage' | 'mist' | 'lavender'> = {
  news: 'mist',
  guide: 'sage',
  editorial: 'lavender',
  update: 'default',
};
---

<article
  class:list={[
    'cozy-card flex min-w-0 flex-col p-6',
    compact ? 'h-auto lg:h-full' : 'h-full',
  ]}
>
  <div class="mb-3 flex min-w-0 flex-wrap items-center gap-2">
    <Badge variant={categoryVariants[article.category]}>{article.category}</Badge>
    {
      game && (
        <a href={`/${game.slug}`} class="hover:opacity-90">
          <Badge variant="default">{getGameDisplayName(game, 'short')}</Badge>
        </a>
      )
    }
    {article.trending && <Badge variant="blossom">Trending</Badge>}
  </div>
  <h3 class="font-display line-clamp-2 min-w-0 text-lg text-primary">
    <a href={getArticleHref(article)} class="hover:text-accent transition-colors">
      {article.title}
    </a>
  </h3>
  <p
    class:list={[
      'mt-2 min-w-0 text-sm text-secondary',
      compact ? 'line-clamp-2 lg:flex-1 lg:min-h-0' : 'flex-1 line-clamp-3',
    ]}
  >
    {article.excerpt}
  </p>
  <footer
    class:list={[
      'flex shrink-0 items-center gap-3 text-xs text-muted',
      compact ? 'mt-4 pt-0 lg:mt-auto lg:pt-4' : 'mt-4',
    ]}
  >
    <time datetime={article.publishedAt}>
      {new Date(article.publishedAt).toLocaleDateString('en-US', {
        month: 'short',
        day: 'numeric',
        year: 'numeric',
      })}
    </time>
    <span aria-hidden="true">·</span>
    <span>{article.readTime} read</span>
  </footer>
</article>
