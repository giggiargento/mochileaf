---
import type { Article } from '../../types';
import Badge from '../ui/Badge.astro';
import { getGame } from '../../data/games';
import { getArticleHref } from '../../utils/article-routes';
import { getGameDisplayName } from '../../utils/game-display';
import { localePath, resolveLocale } from '../../i18n/locale';
import { t } from '../../i18n/messages';

interface Props {
  article: Article;
  /** Home trending column: 2-line excerpt + ellipsis, card height unchanged */
  compact?: boolean;
}

const { article, compact = false } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const game = article.gameSlug ? getGame(article.gameSlug) : undefined;
const articleHref = getArticleHref(article, locale);
const gameHref = game ? localePath(`/${game.slug}`, locale) : undefined;

const categoryVariants: Record<Article['category'], 'default' | 'sage' | 'mist' | 'lavender'> = {
  news: 'mist',
  guide: 'sage',
  editorial: 'lavender',
  update: 'default',
};
---

<article
  class:list={[
    'cozy-card flex min-w-0 flex-col p-6',
    compact ? 'h-auto lg:h-full' : 'h-full',
  ]}
>
  <div class="mb-3 flex min-w-0 flex-wrap items-center gap-2">
    <Badge variant={categoryVariants[article.category]}>
      {t(`badge.${article.category}`, locale)}
    </Badge>
    {
      game && gameHref && (
        <a href={gameHref} class="hover:opacity-90">
          <Badge variant="default">{getGameDisplayName(game, 'short')}</Badge>
        </a>
      )
    }
    {article.trending && <Badge variant="blossom">{t('badge.trending', locale)}</Badge>}
  </div>
  <h3 class="article-card-title--lines-2 font-display min-w-0 text-lg text-primary">
    <a
      href={articleHref}
      class="hover:text-accent transition-colors"
      data-astro-reload
    >
      {article.title}
    </a>
  </h3>
  <p
    class:list={[
      'mt-2 min-w-0 text-sm leading-snug text-secondary',
      compact ? 'article-card-excerpt--lines-2' : 'article-card-excerpt--lines-3 flex-1',
    ]}
  >
    {article.excerpt}
  </p>
  <footer
    class:list={[
      'flex shrink-0 items-center gap-3 text-xs text-muted',
      compact ? 'mt-4 pt-0 lg:mt-auto lg:pt-4' : 'mt-4',
    ]}
  >
    <time datetime={article.publishedAt}>
      {new Date(article.publishedAt).toLocaleDateString(locale === 'es' ? 'es' : 'en-US', {
        month: 'short',
        day: 'numeric',
        year: 'numeric',
      })}
    </time>
    <span aria-hidden="true">·</span>
    <span>{t('article.readTime', locale, { time: article.readTime })}</span>
  </footer>
</article>
