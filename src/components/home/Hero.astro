---
import fs from 'node:fs';
import path from 'node:path';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { localePath, resolveLocale } from '../../i18n/locale';
import { t } from '../../i18n/messages';

const locale = resolveLocale(Astro.currentLocale);

const heroImagePath = '/images/hero-image.png';
const heroImageExists = fs.existsSync(
  path.join(process.cwd(), 'public', 'images', 'hero-image.png'),
);

const heroImageAlt =
  'Illustration of a cozy fantasy gaming world — warm light, soft nature, and peaceful adventure';
---

<section class="page-container py-12 md:py-16 lg:py-20">
  <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-12 xl:gap-16">
    <div class="animate-fade-in text-left">
      <p
        class="mb-4 inline-flex items-center gap-2 rounded-[var(--radius-pill)] border border-default bg-nav px-4 py-1.5 text-sm font-medium text-accent"
      >
        <Icon name="sparkle" size={16} weight="regular" />
        {t('home.hero.eyebrow', locale)}
      </p>
      <h1 class="font-display text-4xl text-primary text-balance leading-tight md:text-5xl lg:text-[3.25rem]">
        {t('home.hero.title', locale)}
        <span class="italic text-accent">{t('home.hero.titleAccent', locale)}</span>
      </h1>
      <p class="mt-6 max-w-xl text-lg text-secondary leading-relaxed">
        {t('home.hero.description', locale)}
      </p>
      <div class="mt-8 grid grid-cols-2 gap-3 md:mt-10 md:flex md:flex-wrap md:items-center md:justify-start md:gap-4">
        <Button
          href={localePath('/games', locale)}
          size="lg"
          class="hero-cta-btn w-full min-w-0 justify-center md:w-auto"
        >
          <Icon name="game-controller" size={18} weight="regular" class="hero-cta-btn-icon shrink-0 text-white" />
          {t('home.hero.ctaGames', locale)}
        </Button>
        <Button
          href={localePath('/articles', locale)}
          variant="secondary"
          size="lg"
          class="hero-cta-btn w-full min-w-0 justify-center md:w-auto"
        >
          <Icon name="article" size={18} weight="regular" class="hero-cta-btn-icon shrink-0" />
          {t('home.hero.ctaArticles', locale)}
        </Button>
      </div>
    </div>

    <div class="animate-fade-in lg:justify-self-end">
      {
        heroImageExists ? (
          <img
            src={heroImagePath}
            alt={heroImageAlt}
            width={640}
            height={640}
            class="mx-auto w-full max-w-lg object-contain lg:max-w-none"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        ) : (
          <div
            class="mx-auto aspect-square w-full max-w-lg rounded-[var(--radius-card)] bg-gradient-to-br from-sage-200 via-mist-100 to-blossom-100 shadow-card dark:from-sage-600/25 dark:via-mist-300/15 dark:to-blossom-300/15 lg:max-w-none"
            aria-hidden="true"
          />
        )
      }
    </div>
  </div>
</section>
