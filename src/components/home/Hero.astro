---
import Button from '../ui/Button.astro';
---

<section class="relative overflow-hidden px-6 py-16 md:py-24 lg:px-12">
  <div class="mx-auto max-w-4xl text-center animate-fade-in">
    <p class="mb-4 inline-flex items-center gap-2 rounded-[var(--radius-pill)] border border-sage-200/60 bg-sage-100/50 px-4 py-1.5 text-sm font-medium text-sage-500 dark:border-sage-500/30 dark:bg-sage-500/10 dark:text-sage-200">
      <span aria-hidden="true">✨</span> Cozy gaming, beautifully told
    </p>
    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-ink-700 text-balance leading-tight dark:text-cream-50">
      Where peaceful play meets
      <span class="italic text-sage-500 dark:text-sage-300">editorial elegance</span>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-400 leading-relaxed dark:text-ink-200">
      Mochileaf is your warm sanctuary for guides, builds, and stories — inspired by soft fantasy,
      Studio Ghibli atmospheres, and the gentle rhythm of cozy gaming culture.
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <Button href="#games" size="lg">Explore games</Button>
      <Button href="#articles" variant="secondary" size="lg">Read articles</Button>
    </div>
  </div>

  <div class="mx-auto mt-16 grid max-w-5xl grid-cols-3 gap-4 opacity-90 md:gap-6" aria-hidden="true">
    <div class="aspect-[4/5] rounded-[var(--radius-card)] bg-gradient-to-br from-sage-200 to-mist-100 shadow-card dark:from-sage-500/20 dark:to-mist-300/10" />
    <div class="aspect-[4/5] rounded-[var(--radius-card)] bg-gradient-to-br from-blossom-200 to-honey-100 shadow-card translate-y-4 dark:from-blossom-300/20 dark:to-honey-300/10" />
    <div class="aspect-[4/5] rounded-[var(--radius-card)] bg-gradient-to-br from-lavender-200 to-mist-100 shadow-card dark:from-lavender-300/20 dark:to-mist-300/10" />
  </div>
</section>
