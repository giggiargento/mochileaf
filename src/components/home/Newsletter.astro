---
---

<section class="px-6 py-16 lg:px-12" aria-labelledby="newsletter-heading">
  <div class="mx-auto max-w-3xl cozy-card p-8 md:p-12 text-center bg-gradient-to-br from-sage-50/80 via-cream-50 to-blossom-50/50 dark:from-ink-800/80 dark:via-ink-900 dark:to-ink-800/80">
    <h2 id="newsletter-heading" class="font-display text-2xl md:text-3xl text-ink-700 dark:text-cream-100">
      Tea &amp; updates, delivered gently
    </h2>
    <p class="mt-3 text-ink-400 dark:text-ink-300">
      No spam — just cozy patch notes, new guides, and soft announcements when the leaves turn.
    </p>
    <form class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center" action="#" method="post">
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        type="email"
        id="newsletter-email"
        name="email"
        placeholder="you@cozy.email"
        required
        class="w-full sm:max-w-xs rounded-[var(--radius-pill)] border border-cream-200 bg-white px-5 py-3 text-sm text-ink-600 placeholder:text-ink-300 focus:outline-none focus:ring-2 focus:ring-sage-300 dark:border-ink-600 dark:bg-ink-800 dark:text-cream-100 dark:placeholder:text-ink-400"
      />
      <button
        type="submit"
        class="rounded-[var(--radius-pill)] bg-sage-400 px-6 py-3 text-sm font-semibold text-white shadow-soft hover:bg-sage-500 transition-colors dark:bg-sage-500 dark:hover:bg-sage-400"
      >
        Subscribe
      </button>
    </form>
    <p class="mt-4 text-xs text-ink-300 dark:text-ink-400">API-ready · Connect your newsletter service later</p>
  </div>
</section>
