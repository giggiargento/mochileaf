---
import Icon from '../ui/Icon.astro';
import { usePageLocale } from '../../lib/i18n/use-page-locale';

const { tr, p } = usePageLocale(Astro.currentLocale);
---

<section class="page-container py-16" aria-labelledby="newsletter-heading">
  <div class="panel-soft p-8 md:p-12 text-center transition-all duration-300 hover:shadow-[var(--shadow-lift)]">
    <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-sage-100 text-accent">
      <Icon name="envelope-simple" size={26} weight="regular" />
    </div>
    <h2 id="newsletter-heading" class="font-display text-2xl md:text-3xl text-primary">
      {tr('newsletter.title')}
    </h2>
    <p class="mt-3 text-secondary max-w-lg mx-auto">
      {tr('newsletter.description')}
    </p>
    <div class="mt-8 flex flex-col items-center gap-3">
      <a
        href={p('/subscribe')}
        data-astro-reload
        class="inline-flex items-center justify-center gap-2 rounded-[var(--radius-pill)] bg-sage-500 px-8 py-3 text-sm font-semibold text-white shadow-soft transition-all duration-300 hover:-translate-y-0.5 hover:bg-sage-600"
      >
        <Icon name="paper-plane-tilt" size={18} weight="regular" class="text-white" />
        {tr('newsletter.cta')}
      </a>
      <p class="max-w-md text-xs text-muted">
        {tr('newsletter.hint')}
      </p>
    </div>
  </div>
</section>
