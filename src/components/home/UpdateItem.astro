---
import type { Update } from '../../types';
import { articles } from '../../data/articles';
import { getGame } from '../../data/games';
import { getArticleHref } from '../../utils/article-routes';
import { getGameDisplayName } from '../../utils/game-display';
import Icon from '../ui/Icon.astro';

interface Props {
  update: Update;
}

const { update } = Astro.props;
const game = update.gameSlug ? getGame(update.gameSlug) : undefined;

let href = update.gameSlug ? `/${update.gameSlug}/news` : '/articles';
if (update.articleSlug && update.gameSlug) {
  const article = articles.find(
    (a) => a.slug === update.articleSlug && a.gameSlug === update.gameSlug,
  );
  if (article) href = getArticleHref(article);
}

const typeLabels: Record<Update['type'], string> = {
  patch: 'Patch',
  event: 'Event',
  content: 'New content',
  community: 'Community',
};

const typeIcons: Record<Update['type'], string> = {
  patch: 'cloud',
  event: 'calendar-star',
  content: 'book-open',
  community: 'users-three',
};
---

<li class="flex gap-4 py-4">
  <div
    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-nav text-accent"
    aria-hidden="true"
  >
    <Icon name={typeIcons[update.type]} size={20} weight="regular" />
  </div>
  <div class="min-w-0 flex-1">
    <p class="text-xs font-medium uppercase tracking-wide text-accent">{typeLabels[update.type]}</p>
    <h3 class="mt-0.5 font-medium leading-snug">
      <a href={href} class="cozy-link no-underline hover:underline">
        {update.title}
      </a>
    </h3>
    <p class="mt-1 text-sm text-muted">
      {
        game ? (
          <>
            <a href={`/${game.slug}`} class="cozy-link no-underline hover:underline">
              {getGameDisplayName(game, 'short')}
            </a>
            {' · '}
          </>
        ) : null
      }
      <time datetime={update.date}>
        {new Date(update.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
      </time>
    </p>
  </div>
</li>
