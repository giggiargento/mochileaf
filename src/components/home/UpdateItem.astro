---
import type { Update } from '../../types';
import { getGame } from '../../data/games';

interface Props {
  update: Update;
}

const { update } = Astro.props;
const game = update.gameSlug ? getGame(update.gameSlug) : undefined;

const typeLabels: Record<Update['type'], string> = {
  patch: 'Patch',
  event: 'Event',
  content: 'New content',
  community: 'Community',
};
---

<li class="flex gap-4 py-4 border-b border-cream-200 last:border-0 dark:border-ink-700">
  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-sage-100 text-sage-500 dark:bg-sage-500/20 dark:text-sage-200" aria-hidden="true">
    {update.type === 'patch' && '☁️'}
    {update.type === 'event' && '🎋'}
    {update.type === 'content' && '📖'}
    {update.type === 'community' && '🍵'}
  </div>
  <div class="min-w-0 flex-1">
    <p class="text-xs font-medium uppercase tracking-wide text-sage-400">{typeLabels[update.type]}</p>
    <p class="mt-0.5 font-medium text-ink-600 dark:text-cream-100">{update.title}</p>
    <p class="mt-1 text-sm text-ink-300 dark:text-ink-400">
      {game ? `${game.name} · ` : ''}
      <time datetime={update.date}>
        {new Date(update.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
      </time>
    </p>
  </div>
</li>
