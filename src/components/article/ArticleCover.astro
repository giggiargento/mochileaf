---
import CozyImage from '../ui/CozyImage.astro';

interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="article-cover">
  <CozyImage src={src} alt={alt} width={1200} height={675} loading="eager" />
  {caption && <figcaption class="article-cover-caption">{caption}</figcaption>}
</figure>
