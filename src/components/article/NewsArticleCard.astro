---
import type { Article } from '../../types';
import CozyImage from '../ui/CozyImage.astro';
import Badge from '../ui/Badge.astro';
import { getGame } from '../../data/games';
import { getArticleHref } from '../../utils/article-routes';
import { getGameDisplayName } from '../../utils/game-display';
import { defaultLocale, type Locale } from '../../i18n/config';
import { pathForLocale } from '../../i18n/routing';
import { t } from '../../i18n/messages';

interface Props {
  article: Article;
  locale?: Locale;
  /** Hide hub badge when listing news inside that game's hub */
  hideGameBadge?: boolean;
}

const { article, locale = defaultLocale, hideGameBadge = true } = Astro.props;
const game = article.gameSlug ? getGame(article.gameSlug) : undefined;
const href = getArticleHref(article, locale);
const gameHref = game ? pathForLocale(`/${game.slug}`, locale) : undefined;
const hasCover = Boolean(article.coverImage);

const categoryVariants: Record<Article['category'], 'default' | 'sage' | 'mist' | 'lavender'> = {
  news: 'mist',
  guide: 'sage',
  editorial: 'lavender',
  update: 'default',
};
---

<article class="news-masonry-item">
  <div class="cozy-card flex min-w-0 flex-col overflow-hidden">
    {
      hasCover && (
        <a
          href={href}
          class="news-masonry-media block overflow-hidden"
          data-astro-reload
          aria-label={`Read: ${article.title}`}
        >
          <CozyImage
            src={article.coverImage!}
            alt={article.title}
            width={640}
            height={360}
            class="news-masonry-img"
            loading="lazy"
          />
        </a>
      )
    }
    <div class="flex min-w-0 flex-col p-6">
      <div class="mb-3 flex min-w-0 flex-wrap items-center gap-2">
        <Badge variant={categoryVariants[article.category]}>
      {t(`badge.${article.category}`, locale)}
    </Badge>
        {
          !hideGameBadge && game && (
            <a href={gameHref} class="hover:opacity-90">
              <Badge variant="default">{getGameDisplayName(game, 'short')}</Badge>
            </a>
          )
        }
        {article.trending && <Badge variant="blossom">{t('badge.trending', locale)}</Badge>}
      </div>
      <h3 class="article-card-title--lines-2 font-display min-w-0 text-lg text-primary">
        <a href={href} class="hover:text-accent transition-colors" data-astro-reload>
          {article.title}
        </a>
      </h3>
      <p class="article-card-excerpt--lines-3 mt-2 min-w-0 text-sm leading-snug text-secondary">
        {article.excerpt}
      </p>
      <footer class="mt-4 flex shrink-0 items-center gap-3 text-xs text-muted">
        <time datetime={article.publishedAt}>
          {new Date(article.publishedAt).toLocaleDateString(locale === 'es' ? 'es' : 'en-US', {
            month: 'short',
            day: 'numeric',
            year: 'numeric',
          })}
        </time>
        <span aria-hidden="true">·</span>
        <span>{t('article.readTime', locale, { time: article.readTime })}</span>
      </footer>
    </div>
  </div>
</article>
