---
import type { Article } from '../../types';
import type { Game } from '../../types';
import ArticleCover from './ArticleCover.astro';
import { getArticleListHref, getArticleListLabel } from '../../utils/article-routes';
import { getGameDisplayName } from '../../utils/game-display';
import { defaultLocale, type Locale } from '../../i18n/config';
import { pathForLocale } from '../../i18n/routing';
import { t } from '../../i18n/messages';

interface Props {
  article: Article;
  game?: Game;
  locale?: Locale;
  coverImage?: string;
  coverCaption?: string;
}

const { article, game, locale = defaultLocale, coverImage, coverCaption } = Astro.props;
const heroSrc = coverImage ?? article.coverImage;
const heroCaption = coverCaption ?? article.coverCaption;
const backHref = getArticleListHref(article, locale);
const backLabel = getArticleListLabel(article, locale);
const gameHref = game ? pathForLocale(`/${game.slug}`, locale) : undefined;
---

<a href={backHref} class="cozy-link text-sm font-medium" data-astro-reload>
  ← {backLabel}
</a>

<article class="article-column mt-8">
  <p class="text-sm text-muted mb-8">
    {article.readTime} ·{' '}
    {new Date(article.publishedAt).toLocaleDateString(locale === 'es' ? 'es' : 'en-US', {
      dateStyle: 'long',
    })}
    {game && (
      <>
        {' '}
        · <a href={gameHref} class="cozy-link">{getGameDisplayName(game, 'short')}</a>
      </>
    )}
  </p>
  {
    heroSrc && (
      <ArticleCover
        src={heroSrc}
        alt={article.title}
        caption={heroCaption}
      />
    )
  }
  <div class="prose-cozy space-y-6">
    <slot />
  </div>
</article>
