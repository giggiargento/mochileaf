---
import type { TierEntry } from '../../types';
import { localePath, resolveLocale } from '../../i18n/locale';

interface Props {
  entry: TierEntry;
  gameSlug?: string;
}

const { entry, gameSlug } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);

const tierColors: Record<TierEntry['tier'], string> = {
  S: 'bg-sage-200 text-sage-600 dark:bg-sage-600/30 dark:text-sage-200',
  A: 'bg-mist-200 text-mist-300 dark:bg-mist-300/20 dark:text-mist-100',
  B: 'bg-lavender-200 text-lavender-300 dark:bg-lavender-300/20 dark:text-lavender-100',
  C: 'bg-honey-200 text-honey-300 dark:bg-honey-300/20 dark:text-honey-200',
  D: 'bg-muted text-muted',
};
---

<div class="cozy-card flex flex-col sm:flex-row gap-4 p-5">
  <div
    class:list={[
      'flex h-12 w-12 shrink-0 items-center justify-center rounded-xl font-display text-xl font-bold',
      tierColors[entry.tier],
    ]}
  >
    {entry.tier}
  </div>
  <div class="flex flex-wrap gap-2 items-center">
    {
      entry.members.map((member) => {
        const href =
          gameSlug && member.slug
            ? localePath(`/${gameSlug}/characters/${member.slug}`, locale)
            : undefined;
        return href ? (
          <a
            href={href}
            class="rounded-[var(--radius-pill)] bg-muted px-4 py-2 text-sm font-medium text-secondary transition-colors hover:bg-sage-100 hover:text-accent dark:hover:bg-sage-600/20"
            data-astro-reload
          >
            {member.label}
          </a>
        ) : (
          <span class="rounded-[var(--radius-pill)] bg-muted px-4 py-2 text-sm font-medium text-secondary">
            {member.label}
          </span>
        );
      })
    }
  </div>
</div>
