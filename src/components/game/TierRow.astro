---
import type { TierEntry } from '../../types';

interface Props {
  entry: TierEntry;
}

const { entry } = Astro.props;

const tierColors: Record<TierEntry['tier'], string> = {
  S: 'bg-sage-200 text-sage-600 dark:bg-sage-600/30 dark:text-sage-200',
  A: 'bg-mist-200 text-mist-300 dark:bg-mist-300/20 dark:text-mist-100',
  B: 'bg-lavender-200 text-lavender-300 dark:bg-lavender-300/20 dark:text-lavender-100',
  C: 'bg-honey-200 text-honey-300 dark:bg-honey-300/20 dark:text-honey-200',
  D: 'bg-muted text-muted',
};
---

<div class="cozy-card flex flex-col sm:flex-row gap-4 p-5">
  <div class:list={['flex h-12 w-12 shrink-0 items-center justify-center rounded-xl font-display text-xl font-bold', tierColors[entry.tier]]}>
    {entry.tier}
  </div>
  <div class="flex flex-wrap gap-2 items-center">
    {entry.characters.map((name) => (
      <span class="rounded-[var(--radius-pill)] bg-muted px-4 py-2 text-sm font-medium text-secondary">
        {name}
      </span>
    ))}
  </div>
</div>
