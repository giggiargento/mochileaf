---
interface Props {
  columns?: 2 | 3 | 4;
  class?: string;
}

const { columns = 3, class: className = '' } = Astro.props;

const colClasses = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
};
---

<div class:list={['grid gap-6', colClasses[columns], className]}>
  <slot />
</div>
