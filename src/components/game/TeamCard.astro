---
import type { Team } from '../../types';
import Badge from '../ui/Badge.astro';
import { getCharacter } from '../../data/characters';

interface Props {
  team: Team;
  gameSlug: string;
}

const { team, gameSlug } = Astro.props;

const difficultyLabels = {
  easy: 'Relaxed',
  medium: 'Balanced',
  hard: 'Focused',
};

const members = team.memberSlugs
  .map((slug) => getCharacter(gameSlug, slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));
---

<article class="cozy-card overflow-hidden">
  <div class="flex flex-wrap gap-2 p-6 pb-0">
    {team.tags.map((tag) => (
      <Badge variant="lavender" size="sm">{tag}</Badge>
    ))}
  </div>
  <div class="p-6 pt-4">
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">{team.focus}</p>
    <h3 class="mt-1 font-display text-xl text-primary">{team.name}</h3>
    <p class="mt-3 text-sm text-secondary">{team.summary}</p>
    <ul class="mt-5 flex flex-wrap gap-2" aria-label="Recommended members">
      {
        members.map((c) => (
          <li>
            <a
              href={`/${gameSlug}/characters/${c.slug}`}
              class="inline-flex items-center gap-2 rounded-full bg-muted px-3 py-1.5 text-sm font-medium text-secondary transition-colors hover:text-accent"
              data-astro-reload
            >
              {
                c.image ? (
                  <img
                    src={c.image}
                    alt=""
                    width={24}
                    height={24}
                    class="h-6 w-6 rounded-full object-cover object-top"
                    loading="lazy"
                    decoding="async"
                  />
                ) : null
              }
              {c.name}
            </a>
          </li>
        ))
      }
    </ul>
    <p class="mt-4 text-xs font-medium text-muted">{difficultyLabels[team.difficulty]}</p>
  </div>
</article>
