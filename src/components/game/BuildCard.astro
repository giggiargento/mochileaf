---
import type { Build } from '../../types';
import Badge from '../ui/Badge.astro';

interface Props {
  build: Build;
}

const { build } = Astro.props;

const difficultyLabels = {
  easy: 'Relaxed',
  medium: 'Balanced',
  hard: 'Focused',
};
---

<article class="cozy-card p-6">
  <div class="flex flex-wrap gap-2 mb-3">
    {build.tags.map((tag) => (
      <Badge variant="sage" size="sm">{tag}</Badge>
    ))}
  </div>
  <h3 class="font-display text-lg text-primary">{build.name}</h3>
  <p class="mt-2 text-sm text-secondary">{build.summary}</p>
  <p class="mt-4 text-xs font-medium text-accent">{difficultyLabels[build.difficulty]}</p>
</article>
