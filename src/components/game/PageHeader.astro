---
interface Props {
  title: string;
  description?: string;
  badge?: string;
}

const { title, description, badge } = Astro.props;
---

<header class="px-6 py-10 lg:px-12 border-b border-cream-200/60 dark:border-ink-700/40 animate-fade-in">
  {badge && (
    <p class="mb-2 text-xs font-medium uppercase tracking-widest text-sage-400">{badge}</p>
  )}
  <h1 class="font-display text-3xl md:text-4xl text-ink-700 dark:text-cream-100">{title}</h1>
  {description && (
    <p class="mt-3 max-w-2xl text-ink-400 leading-relaxed dark:text-ink-300">{description}</p>
  )}
</header>
