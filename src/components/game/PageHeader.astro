---
interface Props {
  title: string;
  description?: string;
  badge?: string;
}

const { title, description, badge } = Astro.props;
---

<header class="animate-fade-in">
  <div class="page-container pt-10 pb-4 lg:pt-12 text-left">
    {badge && (
      <p class="mb-2 text-xs font-medium uppercase tracking-widest text-accent">{badge}</p>
    )}
    <h1 class="font-display text-3xl md:text-4xl text-primary">{title}</h1>
    {description && (
      <p class="mt-3 max-w-2xl text-secondary leading-relaxed">{description}</p>
    )}
  </div>
</header>
