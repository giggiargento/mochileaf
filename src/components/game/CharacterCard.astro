---
import type { Character } from '../../types';
import Badge from '../ui/Badge.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  character: Character;
  gameSlug: string;
}

const { character, gameSlug } = Astro.props;

const tierVariants: Record<string, 'sage' | 'mist' | 'lavender' | 'default'> = {
  S: 'sage',
  A: 'mist',
  B: 'lavender',
  C: 'default',
};

const portraitAlt = `${character.name} — ${character.role}`;
---

<a href={`/${gameSlug}/characters/${character.slug}`} class="cozy-card group block overflow-hidden">
  <div class="relative aspect-[16/10] overflow-hidden">
    {
      character.image ? (
        <img
          src={character.image}
          alt={portraitAlt}
          width={460}
          height={288}
          class="pixel-portrait h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.02]"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div
          class="flex h-full w-full items-center justify-center bg-gradient-to-br from-sage-100 to-mist-100 dark:from-sage-600/25 dark:to-mist-300/15"
          aria-hidden="true"
        >
          <Icon name="user-circle" size={48} weight="light" class="text-accent" />
        </div>
      )
    }
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/25 via-transparent to-transparent"
      aria-hidden="true"
    />
  </div>
  <div class="p-6">
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-display text-xl text-primary group-hover:text-accent transition-colors duration-300">
        {character.name}
      </h3>
      {character.tier && <Badge variant={tierVariants[character.tier]}>{character.tier}</Badge>}
    </div>
    <p class="mt-2 text-sm font-medium text-accent">{character.role}</p>
    {character.element && (
      <p class="mt-1 text-xs font-medium uppercase tracking-wide text-muted">{character.element}</p>
    )}
    <p class="mt-2 text-sm text-secondary line-clamp-2">{character.description}</p>
  </div>
</a>
