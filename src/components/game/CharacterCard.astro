---
import type { Character } from '../../types';
import Badge from '../ui/Badge.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  character: Character;
  gameSlug: string;
}

const { character, gameSlug } = Astro.props;

const tierVariants: Record<string, 'sage' | 'mist' | 'lavender' | 'default'> = {
  S: 'sage',
  A: 'mist',
  B: 'lavender',
  C: 'default',
};
---

<a href={`/${gameSlug}/characters/${character.slug}`} class="cozy-card block p-6 group">
  <div class="aspect-square rounded-2xl bg-gradient-to-br from-sage-100 to-mist-100 mb-4 flex items-center justify-center text-accent dark:from-sage-600/25 dark:to-mist-300/15" aria-hidden="true">
    <Icon name="user-circle" size={40} weight="light" />
  </div>
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-display text-lg text-primary group-hover:text-accent transition-colors duration-300">
      {character.name}
    </h3>
    {character.tier && <Badge variant={tierVariants[character.tier]}>{character.tier}</Badge>}
  </div>
  <p class="text-sm font-medium text-accent">{character.role}</p>
  <p class="mt-2 text-sm text-secondary line-clamp-2">{character.description}</p>
</a>
