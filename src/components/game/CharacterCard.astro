---
import type { Character } from '../../types';
import Badge from '../ui/Badge.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  character: Character;
  gameSlug: string;
}

const { character, gameSlug } = Astro.props;

const tierVariants: Record<string, 'sage' | 'mist' | 'lavender' | 'default'> = {
  S: 'sage',
  A: 'mist',
  B: 'lavender',
  C: 'default',
};

const portraitAlt = `${character.name} — ${character.role}`;
---

<a
  href={`/${gameSlug}/characters/${character.slug}`}
  class="cozy-card group relative block p-5 sm:p-6"
  data-astro-reload
>
  {
    character.tier && (
      <Badge
        variant={tierVariants[character.tier]}
        class="absolute top-5 right-5 z-10 sm:top-6 sm:right-6"
      >
        {character.tier}
      </Badge>
    )
  }
  <div
    class:list={[
      'flex items-center gap-4 sm:gap-5',
      character.tier && 'pr-10 sm:pr-12',
    ]}
  >
    <div class="character-card-avatar shrink-0">
      {
        character.image ? (
          <img
            src={character.image}
            alt={portraitAlt}
            width={96}
            height={96}
            class="character-card-avatar-img pixel-portrait"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="character-card-avatar-placeholder">
            <Icon name="user-circle" size={40} weight="light" class="text-accent" />
          </div>
        )
      }
    </div>
    <div class="min-w-0 flex-1 text-left">
      <h3 class="font-display text-lg leading-tight text-primary transition-colors duration-300 group-hover:text-accent sm:text-xl">
        {character.name}
      </h3>
      <p class="mt-1 text-sm font-medium text-accent">{character.role}</p>
      {
        (character.personality || character.species || character.element) && (
          <p class="mt-0.5 text-xs font-medium uppercase tracking-wide text-muted">
            {[character.personality, character.species, character.element].filter(Boolean).join(' · ')}
          </p>
        )
      }
    </div>
  </div>
</a>
