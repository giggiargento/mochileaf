---
import type { Character } from '../../types';
import { localePath, resolveLocale } from '../../i18n/locale';
import { t } from '../../i18n/messages';
import Badge from '../ui/Badge.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  character: Character;
  gameSlug: string;
}

const { character, gameSlug } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);

function personalityLabel(value: string | undefined): string | undefined {
  if (!value) return undefined;
  const key = `acnh.personality.${value.replace(/\s+/g, '')}`;
  const translated = t(key, locale);
  return translated !== key ? translated : value;
}
const characterHref = localePath(`/${gameSlug}/characters/${character.slug}`, locale);

const tierVariants: Record<string, 'sage' | 'mist' | 'lavender' | 'default'> = {
  S: 'sage',
  A: 'mist',
  B: 'lavender',
  C: 'default',
};

const cornerLabel = character.tier ?? personalityLabel(character.personality);
const cornerVariant = character.tier
  ? tierVariants[character.tier]
  : 'mist';

/** ACNH: personality is the corner badge — subtitle is species only (e.g. Bear cub, not "Smug cat"). */
const personalityInCorner = character.personality === cornerLabel;

/** Animal label after personality in role ("Normal bear cub" → "bear cub") when it matches species. */
function cardSpeciesLabel(): string | undefined {
  if (!character.species) return undefined;
  if (character.role) {
    const tail = character.role.replace(/^\S+\s+/, '').trim();
    if (tail.length > character.species.length) return tail;
  }
  return character.species;
}

const accentLine =
  personalityInCorner && cardSpeciesLabel() ? cardSpeciesLabel() : character.role;

const sublineParts = personalityInCorner
  ? []
  : [
      ...(character.personality && personalityLabel(character.personality) !== cornerLabel
        ? [personalityLabel(character.personality)!]
        : []),
      ...(character.species ? [character.species] : []),
      ...(character.element ? [character.element] : []),
    ];

const portraitAlt = `${character.name} — ${character.role}`;
---

<a
  href={characterHref}
  class="cozy-card group relative block p-5 sm:p-6"
  data-astro-reload
>
  {
    cornerLabel && (
      <Badge
        variant={cornerVariant}
        class="absolute top-5 right-5 z-10 sm:top-6 sm:right-6"
      >
        {cornerLabel}
      </Badge>
    )
  }
  <div
    class:list={[
      'flex items-center gap-4 sm:gap-5',
      cornerLabel && 'pr-10 sm:pr-12',
    ]}
  >
    <div class="character-card-avatar shrink-0">
      {
        character.image ? (
          <img
            src={character.image}
            alt={portraitAlt}
            width={96}
            height={96}
            class="character-card-avatar-img pixel-portrait"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="character-card-avatar-placeholder">
            <Icon name="user-circle" size={40} class="text-accent" />
          </div>
        )
      }
    </div>
    <div class="min-w-0 flex-1 text-left">
      <h3 class="font-display text-lg leading-tight text-primary transition-colors duration-300 group-hover:text-accent sm:text-xl">
        {character.name}
      </h3>
      <p class="mt-1 text-sm font-medium text-accent">{accentLine}</p>
      {
        sublineParts.length > 0 && (
          <p class="mt-0.5 text-xs font-medium uppercase tracking-wide text-muted">
            {sublineParts.join(' · ')}
          </p>
        )
      }
    </div>
  </div>
</a>
