---
import type { GameItem } from '../../types';
import Badge from '../ui/Badge.astro';

interface Props {
  item: GameItem;
}

const { item } = Astro.props;

const categoryLabels: Record<GameItem['category'], string> = {
  tool: 'Tool',
  furniture: 'Furniture',
  diy: 'DIY',
  clothing: 'Clothing',
  recipe: 'Recipe',
  other: 'Other',
};
---

<article class="cozy-card overflow-hidden">
  <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-mist-100 to-honey-100 dark:from-mist-300/15 dark:to-honey-300/10">
    {
      item.image ? (
        <img
          src={item.image}
          alt=""
          width={400}
          height={300}
          class="h-full w-full object-contain p-4"
          loading="lazy"
          decoding="async"
        />
      ) : null
    }
  </div>
  <div class="p-6">
    <Badge variant="mist" size="sm">
      {categoryLabels[item.category]}
    </Badge>
    <h3 class="mt-3 font-display text-lg text-primary">{item.name}</h3>
    <p class="mt-2 text-sm text-secondary">{item.summary}</p>
    <p class="mt-3 text-xs text-muted">
      <span class="font-semibold text-accent">How to get:</span>
      {item.howToGet}
    </p>
  </div>
</article>
