---
import type { AcnhCatalogItem } from '../../data/items-acnh';
import CozyImage from '../ui/CozyImage.astro';

interface Props {
  item: AcnhCatalogItem;
  compact?: boolean;
}

const { item, compact = false } = Astro.props;
const howToGet = item.source && item.source !== '—' ? item.source : undefined;
const priceBits = [item.buy && `Buy: ${item.buy}`, item.sell && `Sell: ${item.sell}`]
  .filter(Boolean)
  .join(' · ');
const titleAttr = [howToGet, priceBits].filter(Boolean).join(' — ');
---

<article
  class:list={['item-card', compact && 'item-card--compact', 'cozy-card']}
  title={titleAttr || item.name}
>
  <div class="item-card__media">
    <CozyImage
      src={item.image}
      alt=""
      width={96}
      height={96}
      class="item-card__img"
      loading="lazy"
    />
  </div>
  <div class="item-card__body">
    <h3 class="item-card__name">{item.name}</h3>
    {
      !compact && howToGet && (
        <p class="item-card__meta">
          <span class="font-semibold text-accent">From:</span> {howToGet}
        </p>
      )
    }
    {
      !compact && priceBits && <p class="item-card__price">{priceBits}</p>
    }
  </div>
</article>
