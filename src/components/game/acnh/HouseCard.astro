---
import type { Character } from '../../../types';
import Badge from '../../ui/Badge.astro';

interface Props {
  villager: Character;
  gameSlug: string;
}

const { villager, gameSlug } = Astro.props;
---

<a
  href={`/${gameSlug}/characters/${villager.slug}#house`}
  class="cozy-card group flex flex-col overflow-hidden sm:flex-row"
>
  {
    villager.image && (
      <div class="aspect-[4/3] w-full shrink-0 overflow-hidden bg-gradient-to-br from-mist-100 to-blossom-100 sm:aspect-auto sm:h-auto sm:w-36">
        <img
          src={villager.image}
          alt=""
          width={144}
          height={144}
          class="h-full w-full object-cover object-top sm:h-full"
          loading="lazy"
          decoding="async"
        />
      </div>
    )
  }
  <div class="flex flex-1 flex-col p-5">
    <div class="flex flex-wrap gap-2">
      {villager.personality && <Badge variant="mist" size="sm">{villager.personality}</Badge>}
      {villager.species && <Badge variant="sage" size="sm">{villager.species}</Badge>}
    </div>
    <h3 class="mt-2 font-display text-lg text-primary group-hover:text-accent transition-colors">
      {villager.name}
    </h3>
    {villager.houseStyle && (
      <p class="mt-1 text-sm font-medium text-accent">{villager.houseStyle}</p>
    )}
    {villager.houseDescription && (
      <p class="mt-2 text-sm text-secondary line-clamp-2">{villager.houseDescription}</p>
    )}
    <span class="mt-auto pt-3 text-xs font-semibold text-accent">See interior notes →</span>
  </div>
</a>
