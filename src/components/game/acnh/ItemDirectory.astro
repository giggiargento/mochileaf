---
import type { Game } from '../../../types';
import {
  acnhItemCatalogMeta,
  getAcnhItemCatalogForClient,
  getAcnhItemTabsWithCounts,
} from '../../../data/items-acnh';

interface Props {
  game: Game;
}

const { game } = Astro.props;
const tabs = getAcnhItemTabsWithCounts();
const catalogJson = getAcnhItemCatalogForClient();
const defaultTab = tabs[0]?.id ?? 'housewares';
---

<div
  class="acnh-item-directory"
  data-acnh-item-directory
  data-game-slug={game.slug}
  data-default-tab={defaultTab}
>
  <div class="acnh-item-directory__toolbar">
    <label class="sr-only" for="acnh-item-search">Search items</label>
    <input
      id="acnh-item-search"
      type="search"
      class="acnh-item-directory__search"
      placeholder="Search in this tab…"
      autocomplete="off"
      spellcheck="false"
    />
    <p class="acnh-item-directory__count text-sm text-muted" data-item-count aria-live="polite">
    </p>
  </div>

  <div class="acnh-item-tabs" role="tablist" aria-label="Item categories">
    {
      tabs.map((tab, index) => (
        <button
          type="button"
          role="tab"
          id={`item-tab-${tab.id}`}
          class:list={['acnh-item-tab', index === 0 && 'is-active']}
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-controls={`item-panel-${tab.id}`}
          data-tab={tab.id}
        >
          {tab.label}
          <span class="acnh-item-tab__count">{tab.count}</span>
        </button>
      ))
    }
  </div>

  <div class="acnh-item-panels">
    {
      tabs.map((tab, index) => (
        <section
          id={`item-panel-${tab.id}`}
          role="tabpanel"
          aria-labelledby={`item-tab-${tab.id}`}
          class:list={['acnh-item-panel', index !== 0 && 'hidden']}
          data-tab-panel={tab.id}
          hidden={index !== 0 ? true : undefined}
        >
          <div class="item-card-grid" data-item-grid>
            <p class="col-span-full text-sm text-muted">Loading items…</p>
          </div>
          <div class="acnh-item-pagination" data-item-pagination hidden></div>
        </section>
      ))
    }
  </div>

  <p class="mt-10 text-center text-xs text-muted">
    {acnhItemCatalogMeta.total.toLocaleString()} items · Data from{' '}
    <a
      href={acnhItemCatalogMeta.source}
      class="cozy-link"
      target="_blank"
      rel="noopener noreferrer"
    >
      Nookipedia
    </a>
    {' '}· Images via {acnhItemCatalogMeta.imageCredit}
  </p>

  <script type="application/json" id="acnh-items-catalog" set:html={catalogJson} />
</div>

<script>
  import '../../../scripts/items-directory.client.ts';
</script>
