---
import type { Game } from '../../../types';
import { defaultLocale, type Locale } from '../../../i18n/config';
import { t } from '../../../i18n/messages';
import {
  acnhItemCatalogMeta,
  getAcnhItemCatalogForClient,
  getAcnhItemNamesEsForClient,
  getAcnhItemTabsWithCounts,
} from '../../../data/items-acnh';

interface Props {
  game: Game;
  locale?: Locale;
}

const { game, locale = defaultLocale } = Astro.props;
const tabs = getAcnhItemTabsWithCounts();
const catalogJson = getAcnhItemCatalogForClient();
const namesEsJson = getAcnhItemNamesEsForClient();
const defaultTab = tabs[0]?.id ?? 'housewares';
const itemsI18n = {
  loading: t('page.items.loading', locale),
  noMatch: t('page.items.noMatch', locale),
  showingAll: t('page.items.showingAll', locale, { total: '{total}' }),
  loadMore: t('page.items.loadMore', locale),
  countOf: t('page.items.countOf', locale, { shown: '{shown}', total: '{total}', label: '{label}' }),
  matchCount: t('page.items.matchCount', locale, { match: '{match}', total: '{total}' }),
  buy: t('page.items.buy', locale),
  sell: t('page.items.sell', locale),
  source: t('page.items.source', locale),
};
---

<div
  class="acnh-item-directory"
  data-acnh-item-directory
  data-game-slug={game.slug}
  data-default-tab={defaultTab}
>
  <div class="acnh-item-directory__toolbar">
    <label class="sr-only" for="acnh-item-search">{t('page.items.searchLabel', locale)}</label>
    <input
      id="acnh-item-search"
      type="search"
      class="acnh-item-directory__search"
      placeholder={t('page.items.searchPlaceholder', locale)}
      autocomplete="off"
      spellcheck="false"
    />
    <p class="acnh-item-directory__count text-sm text-muted" data-item-count aria-live="polite">
    </p>
  </div>

  <div class="acnh-item-tabs" role="tablist" aria-label={t('page.items.tablist', locale)}>
    {
      tabs.map((tab, index) => (
        <button
          type="button"
          role="tab"
          id={`item-tab-${tab.id}`}
          class:list={['acnh-item-tab', index === 0 && 'is-active']}
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-controls={`item-panel-${tab.id}`}
          data-tab={tab.id}
        >
          {tab.label}
          <span class="acnh-item-tab__count">{tab.count}</span>
        </button>
      ))
    }
  </div>

  <div class="acnh-item-panels">
    {
      tabs.map((tab, index) => (
        <section
          id={`item-panel-${tab.id}`}
          role="tabpanel"
          aria-labelledby={`item-tab-${tab.id}`}
          class:list={['acnh-item-panel', index !== 0 && 'hidden']}
          data-tab-panel={tab.id}
          hidden={index !== 0 ? true : undefined}
        >
          <div class="item-card-grid" data-item-grid>
            <p class="col-span-full text-sm text-muted">{itemsI18n.loading}</p>
          </div>
          <div class="acnh-item-pagination" data-item-pagination hidden></div>
        </section>
      ))
    }
  </div>

  <p class="mt-10 text-center text-xs text-muted">
    {t('page.items.catalogFooter', locale, {
      total: acnhItemCatalogMeta.total.toLocaleString(),
    })}{' '}
    <a
      href={acnhItemCatalogMeta.source}
      class="cozy-link"
      target="_blank"
      rel="noopener noreferrer"
    >
      Nookipedia
    </a>
    {' '}· {t('page.items.imageCredit', locale)} {acnhItemCatalogMeta.imageCredit}
  </p>

  <script type="application/json" id="acnh-items-catalog" set:html={catalogJson} />
  <script type="application/json" id="acnh-items-names-es" set:html={namesEsJson} />
  <script type="application/json" id="acnh-items-i18n" set:html={JSON.stringify(itemsI18n)} />
</div>

<script>
  import '../../../scripts/items-directory.client.ts';
</script>
