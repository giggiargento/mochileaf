---
import GlobalLayout from '../layouts/GlobalLayout.astro';
import PageHeader from '../components/game/PageHeader.astro';
import { usePageLocale } from '../lib/i18n/use-page-locale';

const { p, tr } = usePageLocale(Astro.currentLocale);
---

<GlobalLayout title={tr('privacy.metaTitle')} description={tr('privacy.metaDescription')}>
  <div class="page-container-below-header max-w-3xl pb-16">
    <PageHeader title={tr('privacy.title')} description={tr('privacy.description')} />

    <div class="prose-cozy space-y-6 text-sm">
      <p>{tr('privacy.intro')}</p>

      <section>
        <h2 class="font-display text-xl text-primary">{tr('privacy.collectTitle')}</h2>
        <ul class="mt-3 list-disc space-y-2 pl-5">
          <li>{tr('privacy.theme')}</li>
          <li>{tr('privacy.analytics')}</li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-xl text-primary">{tr('privacy.adsTitle')}</h2>
        <p class="mt-3">
          {tr('privacy.adsBody')}{' '}
          <a
            href="https://www.google.com/settings/ads"
            class="cozy-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            {tr('privacy.adsSettings')}
          </a>
          {' '}{tr('privacy.adsAnd')}{' '}
          <a
            href="https://policies.google.com/technologies/ads"
            class="cozy-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            {tr('privacy.adsHow')}
          </a>
          .
        </p>
      </section>

      <section>
        <h2 class="font-display text-xl text-primary">{tr('privacy.externalTitle')}</h2>
        <p class="mt-3">{tr('privacy.externalBody')}</p>
      </section>

      <section>
        <h2 class="font-display text-xl text-primary">{tr('privacy.contactTitle')}</h2>
        <p class="mt-3">
          {tr('privacy.contactBody')}{' '}
          <a href={p('/about')} class="cozy-link">{tr('privacy.aboutLink')}</a>
          {tr('privacy.contactSuffix')}
        </p>
      </section>

      <p class="text-xs text-muted">{tr('privacy.updated')}</p>
    </div>
  </div>
</GlobalLayout>
