---
import GlobalLayout from '../../layouts/GlobalLayout.astro';
import PageHeader from '../../components/game/PageHeader.astro';
import ArticleCard from '../../components/home/ArticleCard.astro';
import { loadArticles } from '../../data/articles';

const sorted = await loadArticles();
---

<GlobalLayout
  title="Articles"
  description="Cozy guides, editorials, and gentle gaming stories from the Mochileaf community."
>
  <PageHeader
    badge="Editorial"
    title="Articles"
    description="Walkthroughs, patch notes, and slow-living stories from across our game hubs."
  />

  <div class="page-container-below-header">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((article) => <ArticleCard article={article} />)}
    </div>
  </div>
</GlobalLayout>
