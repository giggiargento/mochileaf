---
import GlobalLayout from '../../layouts/GlobalLayout.astro';
import PageHeader from '../../components/game/PageHeader.astro';
import ArticleDetail from '../../components/article/ArticleDetail.astro';
import { articleSlugFromId, loadArticleEntries } from '../../data/articles';
import { getArticleHref } from '../../utils/article-routes';
import { render } from 'astro:content';
import { resolveContentSeo } from '../../lib/content/seo';

export async function getStaticPaths() {
  const entries = await loadArticleEntries();
  return entries
    .filter((entry) => !entry.data.gameSlug)
    .map((entry) => {
      const slug = articleSlugFromId(entry.id);
      const article = {
        slug,
        title: entry.data.title,
        excerpt: entry.data.excerpt,
        category: entry.data.category,
        gameSlug: entry.data.gameSlug,
        publishedAt: entry.data.publishedAt,
        readTime: entry.data.readTime,
        featured: entry.data.featured,
        trending: entry.data.trending,
        coverImage: entry.data.coverImage,
        coverCaption: entry.data.coverCaption,
      };
      return { params: { slug }, props: { article, entry } };
    });
}

const { article, entry } = Astro.props;

if (article.gameSlug) {
  return Astro.redirect(getArticleHref(article), 301);
}

const { Content } = await render(entry);
const seo = resolveContentSeo(entry.data.seo, {
  title: article.title,
  description: article.excerpt,
});
---

<GlobalLayout title={seo.title} description={seo.description}>
  <PageHeader badge={article.category} title={article.title} description={article.excerpt} />
  <div class="page-container-below-header">
    <ArticleDetail article={article}>
      <Content />
    </ArticleDetail>
  </div>
</GlobalLayout>
