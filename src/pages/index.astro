---
import GlobalLayout from '../layouts/GlobalLayout.astro';
import Hero from '../components/home/Hero.astro';
import SectionHeader from '../components/home/SectionHeader.astro';
import GameCard from '../components/home/GameCard.astro';
import ArticleCard from '../components/home/ArticleCard.astro';
import UpdateItem from '../components/home/UpdateItem.astro';
import Newsletter from '../components/home/Newsletter.astro';
import PromoBanner from '../components/home/PromoBanner.astro';
import AdPlaceholder from '../components/ui/AdPlaceholder.astro';
import { getFeaturedGames } from '../data/games';
import { getFeaturedArticles, getTrendingArticles } from '../data/articles';
import { updates } from '../data/updates';

const featuredGames = getFeaturedGames();
const featuredArticles = getFeaturedArticles();
const trendingArticles = getTrendingArticles().slice(0, 2);
---

<GlobalLayout
  title="Mochileaf"
  description="A warm, elegant cozy gaming platform — guides, builds, tier lists, and editorial stories for peaceful play."
>
  <Hero />

  <section class="page-container py-16">
    <SectionHeader
      title="Featured games"
      subtitle="Each world has its own cozy content hub — guides, builds, and stories."
      href="/games"
      linkLabel="All games"
    />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featuredGames.map((game) => <GameCard game={game} />)}
    </div>
  </section>

  <section class="page-container py-8">
    <AdPlaceholder slot="inline" />
  </section>

  <section class="page-container py-16">
    <div class="grid gap-10 lg:grid-cols-3 lg:items-stretch">
      <div class="lg:col-span-2 flex flex-col">
        <SectionHeader
          title="Latest updates"
          subtitle="Patch notes, events, and gentle announcements."
        />
        <ul class="panel-soft flex-1 divide-y divide-[var(--border-default)] px-6">
          {updates.slice(0, 5).map((update) => <UpdateItem update={update} />)}
        </ul>
      </div>
      <div class="flex flex-col">
        <SectionHeader
          title="Trending"
          subtitle="What the community is reading."
          href="/articles"
          linkLabel="All articles"
        />
        <div class="trending-stack">
          {trendingArticles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <PromoBanner
    title="Slow down. Play softly."
    description="Mochileaf celebrates games that breathe — no rush, no noise. Just warm light and thoughtful guides."
    ctaLabel="Our philosophy"
    ctaHref="/about"
  />

  <section class="page-container py-16">
    <SectionHeader
      title="Featured articles"
      subtitle="Editorial guides and cozy stories from across our hubs."
      href="/articles"
      linkLabel="All articles"
    />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {featuredArticles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <section class="page-container py-8">
    <AdPlaceholder slot="footer" label="Footer ad" />
  </section>

  <Newsletter />
</GlobalLayout>
