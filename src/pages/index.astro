---
import GlobalLayout from '../layouts/GlobalLayout.astro';
import Hero from '../components/home/Hero.astro';
import SectionHeader from '../components/home/SectionHeader.astro';
import GameCard from '../components/home/GameCard.astro';
import ArticleCard from '../components/home/ArticleCard.astro';
import UpdateItem from '../components/home/UpdateItem.astro';
import Newsletter from '../components/home/Newsletter.astro';
import PromoBanner from '../components/home/PromoBanner.astro';
import AdPlaceholder from '../components/ui/AdPlaceholder.astro';
import { getFeaturedGames } from '../data/games';
import { getTrendingArticles, loadArticles, sortArticlesByDateDesc } from '../data/articles';
import { isNewsCategory } from '../utils/article-routes';
import { updates } from '../data/updates';
import { localePath, resolveLocale } from '../i18n/locale';
import { t } from '../i18n/messages';

const locale = resolveLocale(Astro.currentLocale);
const featuredGames = getFeaturedGames(locale);
const allArticles = await loadArticles(locale);
const featuredArticles = sortArticlesByDateDesc(
  allArticles.filter((a) => a.gameSlug && isNewsCategory(a.category) && a.featured),
).slice(0, 4);
const trendingArticles = sortArticlesByDateDesc(
  (await getTrendingArticles(locale)).filter((a) => a.gameSlug && isNewsCategory(a.category)),
).slice(0, 2);
---

<GlobalLayout title={t('home.meta.title', locale)} description={t('home.meta.description', locale)}>
  <Hero />

  <section class="page-container py-16">
    <SectionHeader
      title={t('home.section.featuredGames', locale)}
      subtitle={t('home.section.featuredGamesSub', locale)}
      href={localePath('/games', locale)}
      linkLabel={t('home.section.allGames', locale)}
    />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featuredGames.map((game) => <GameCard game={game} />)}
    </div>
  </section>

  <section class="page-container py-8">
    <AdPlaceholder slot="inline" />
  </section>

  <section class="page-container py-16">
    <div class="grid gap-10 lg:grid-cols-3 lg:items-stretch">
      <div class="lg:col-span-2 flex flex-col">
        <SectionHeader
          title={t('home.section.latestUpdates', locale)}
          subtitle={t('home.section.latestUpdatesSub', locale)}
        />
        <ul class="panel-soft flex-1 divide-y divide-[var(--border-default)] px-6">
          {updates.slice(0, 5).map((update) => <UpdateItem update={update} />)}
        </ul>
      </div>
      <div class="flex min-w-0 flex-col lg:min-h-0">
        <SectionHeader
          title={t('home.section.trending', locale)}
          subtitle={t('home.section.trendingSub', locale)}
          href={localePath('/articles', locale)}
          linkLabel={t('home.section.allArticles', locale)}
        />
        <div class="trending-stack min-w-0">
          {trendingArticles.map((article) => (
            <ArticleCard article={article} compact />
          ))}
        </div>
      </div>
    </div>
  </section>

  <PromoBanner
    title={t('home.promo.title', locale)}
    description={t('home.promo.description', locale)}
    ctaLabel={t('home.promo.cta', locale)}
    ctaHref={localePath('/about', locale)}
  />

  <section class="page-container py-16">
    <SectionHeader
      title={t('home.section.featuredArticles', locale)}
      subtitle={t('home.section.featuredArticlesSub', locale)}
      href={localePath('/articles', locale)}
      linkLabel={t('home.section.allArticles', locale)}
    />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {featuredArticles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <Newsletter />
</GlobalLayout>
