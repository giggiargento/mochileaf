---
import GlobalLayout from '../../layouts/GlobalLayout.astro';
import PageHeader from '../../components/game/PageHeader.astro';
import GameCard from '../../components/home/GameCard.astro';
import { getAllGames } from '../../data/games';
import { usePageLocale } from '../../lib/i18n/use-page-locale';

const { locale, tr } = usePageLocale(Astro.currentLocale);
const activeGames = getAllGames(locale).filter((g) => g.status === 'active');
---

<GlobalLayout title={tr('games.title')} description={tr('games.meta')}>
  <PageHeader
    badge={tr('games.badge')}
    title={tr('games.title')}
    description={tr('games.description')}
  />

  <div class="page-container-below-header">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {activeGames.map((game) => <GameCard game={game} />)}
    </div>
  </div>
</GlobalLayout>
