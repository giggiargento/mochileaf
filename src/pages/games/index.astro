---
import GlobalLayout from '../../layouts/GlobalLayout.astro';
import PageHeader from '../../components/game/PageHeader.astro';
import GameCard from '../../components/home/GameCard.astro';
import { games } from '../../data/games';

const activeGames = games.filter((g) => g.status === 'active');
const comingSoon = games.filter((g) => g.status === 'coming-soon');
---

<GlobalLayout
  title="Games"
  description="Explore cozy game hubs on Mochileaf — guides, builds, characters, and gentle stories for every world."
>
  <PageHeader
    badge="All worlds"
    title="Games"
    description="Each game has its own hub with characters, builds, tier lists, guides, and news."
  />

  <div class="page-container-below-header">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {activeGames.map((game) => <GameCard game={game} />)}
    </div>

    {comingSoon.length > 0 && (
      <div class="mt-14">
        <h2 class="section-title mb-6">Coming soon</h2>
        <div class="grid gap-6 sm:grid-cols-2 max-w-xl">
          {comingSoon.map((game) => <GameCard game={game} />)}
        </div>
      </div>
    )}
  </div>
</GlobalLayout>
