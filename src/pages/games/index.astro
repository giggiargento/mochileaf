---
import GlobalLayout from '../../layouts/GlobalLayout.astro';
import PageHeader from '../../components/game/PageHeader.astro';
import GameCard from '../../components/home/GameCard.astro';
import { routableGames } from '../../lib/content/registry';

const activeGames = routableGames;
---

<GlobalLayout
  title="Games"
  description="Explore cozy game hubs on Mochileaf — guides, builds, characters, and gentle stories for every world."
>
  <PageHeader
    badge="All worlds"
    title="Games"
    description="Each game has its own hub with characters, builds, tier lists, guides, and news."
  />

  <div class="page-container-below-header">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {activeGames.map((game) => <GameCard game={game} />)}
    </div>
  </div>
</GlobalLayout>
