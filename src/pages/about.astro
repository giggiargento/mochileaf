---
import GlobalLayout from '../layouts/GlobalLayout.astro';
import Icon from '../components/ui/Icon.astro';
import { BEACONS_PROFILE } from '../utils/beacons';
import { usePageLocale } from '../lib/i18n/use-page-locale';

const { tr } = usePageLocale(Astro.currentLocale);
---

<GlobalLayout title={tr('aboutGiggi.metaTitle')} description={tr('aboutGiggi.metaDescription')}>
  <header class="animate-fade-in">
    <div class="page-container pt-10 pb-4 text-left lg:pt-12">
      <div class="flex items-start gap-4 sm:gap-5">
        <div
          class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-blossom-100 text-accent sm:h-16 sm:w-16"
          aria-hidden="true"
        >
          <Icon name="user-circle" size={36} weight="regular" />
        </div>
        <div class="min-w-0">
          <p class="mb-2 text-xs font-medium uppercase tracking-widest text-accent">{tr('aboutGiggi.eyebrow')}</p>
          <h1 class="font-display text-3xl text-primary md:text-4xl">{tr('aboutGiggi.heading')}</h1>
        </div>
      </div>
    </div>
  </header>

  <div class="page-container-below-header space-y-14">
    <article class="prose-cozy max-w-3xl">
      <p>{tr('aboutGiggi.p1')}</p>
      <p>{tr('aboutGiggi.p2')}</p>
      <p>{tr('aboutGiggi.p3')}</p>
      <p>{tr('aboutGiggi.p4')}</p>
    </article>

    <section aria-labelledby="mochileaf-story-heading">
      <h2 id="mochileaf-story-heading" class="section-title mb-6 flex items-center gap-2">
        <Icon name="plant" size={22} weight="regular" class="text-accent" aria-hidden="true" />
        {tr('aboutGiggi.storyTitle')}
      </h2>
      <article class="prose-cozy max-w-3xl">
        <p>{tr('aboutGiggi.story1')}</p>
        <p>{tr('aboutGiggi.story2')}</p>
        <p>{tr('aboutGiggi.story3')}</p>
        <p>{tr('aboutGiggi.story4')}</p>
        <p>{tr('aboutGiggi.story5')}</p>
      </article>
    </section>

    <section aria-labelledby="mochileaf-name-heading">
      <h2 id="mochileaf-name-heading" class="section-title mb-6 flex items-center gap-2">
        <Icon name="sparkle" size={22} weight="regular" class="text-accent" aria-hidden="true" />
        {tr('aboutGiggi.nameTitle')}
      </h2>
      <article class="prose-cozy max-w-3xl">
        <p>{tr('aboutGiggi.name1')}</p>
        <p>{tr('aboutGiggi.name2')}</p>
      </article>
    </section>

    <article class="prose-cozy max-w-3xl">
      <p>{tr('aboutGiggi.closing')}</p>
    </article>

    <section
      class="panel-soft w-full p-8 text-center md:p-10"
      aria-labelledby="about-contact-heading"
    >
      <div
        class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-blossom-100 text-accent"
        aria-hidden="true"
      >
        <Icon name="chat-circle" size={26} weight="regular" />
      </div>
      <h2 id="about-contact-heading" class="font-display text-xl text-primary md:text-2xl">
        {tr('aboutGiggi.contactTitle')}
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-secondary">{tr('aboutGiggi.contactBody')}</p>
      <a
        href={BEACONS_PROFILE}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center justify-center gap-2 rounded-[var(--radius-pill)] border border-default bg-page px-6 py-3 text-sm font-semibold text-primary transition-all duration-300 hover:border-sage-300 hover:text-accent"
      >
        {tr('aboutGiggi.contactCta')}
        <Icon name="arrow-square-out" size={16} />
      </a>
    </section>
  </div>
</GlobalLayout>
