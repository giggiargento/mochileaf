---
import GlobalLayout from '../../layouts/GlobalLayout.astro';
import PageHeader from '../../components/game/PageHeader.astro';
import CreatorCard from '../../components/creators/CreatorCard.astro';
import Icon from '../../components/ui/Icon.astro';
import { BEACONS_PROFILE } from '../../utils/beacons';
import { cozyCreators } from '../../data/cozy-creators';
---

<GlobalLayout
  title="Cozy Creators"
  description="Discover cozy gaming creators we love — link in bio pages, channels, and gentle communities to explore."
>
  <PageHeader
    badge="Community"
    title="Cozy Creators"
    description="Friends of Mochileaf who share slow, beautiful play. Visit their pages, say hi."
  />

  <div class="page-container-below-header space-y-14">
    {
      cozyCreators.length > 0 && (
        <section aria-label="Cozy creators">
          <div class="flex flex-col gap-4">
            {cozyCreators.map((creator) => (
              <CreatorCard creator={creator} />
            ))}
          </div>
        </section>
      )
    }

    {
      cozyCreators.length === 0 && (
        <p class="text-secondary text-center max-w-lg mx-auto">
          We are lining up our first cozy collaborators — check back soon.
        </p>
      )
    }

    <section
      class="panel-soft w-full p-8 text-center md:p-10"
      aria-labelledby="collab-heading"
    >
      <div
        class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-blossom-100 text-accent"
        aria-hidden="true"
      >
        <Icon name="heart" size={26} weight="regular" />
      </div>
      <h2 id="collab-heading" class="font-display text-xl text-primary md:text-2xl">
        Want to join Cozy Creators?
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-secondary">
        If you make gentle gaming content and want a spot on this page, reach out — we link to your
        Beacons, channel, or site so Mochileaf visitors can discover you.
      </p>
      <a
        href={BEACONS_PROFILE}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center justify-center gap-2 rounded-[var(--radius-pill)] border border-default bg-page px-6 py-3 text-sm font-semibold text-primary transition-all duration-300 hover:border-sage-300 hover:text-accent"
      >
        Contact via Beacons
        <Icon name="arrow-square-out" size={16} />
      </a>
    </section>
  </div>
</GlobalLayout>
