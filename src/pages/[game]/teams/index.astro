---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import ContentGrid from '../../../components/game/ContentGrid.astro';
import TeamCard from '../../../components/game/TeamCard.astro';
import { games } from '../../../data/games';
import { getTeamsByGame } from '../../../data/teams';
import { usePageLocale } from '../../../lib/i18n/use-page-locale';
import { t } from '../../../i18n/messages';

export function getStaticPaths() {
  return games
    .filter((g) => g.status === 'active' && getTeamsByGame(g.slug).length > 0)
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const { locale, tr } = usePageLocale(Astro.currentLocale);
const teams = getTeamsByGame(game.slug);
const hubLabel = game.shortName ?? 'NTE';
---

<GameHubLayout game={game} title={t('nav.teams', locale)} description={tr('teams.meta', { game: game.name })}>
  <PageHeader
    title={tr('teams.title')}
    description={tr('teams.description', { hub: hubLabel })}
  />
  <div class="page-container-below-header">
    <ContentGrid columns={2}>
      {teams.map((team, i) => (
        <TeamCard team={team} gameSlug={game.slug} index={i + 1} />
      ))}
    </ContentGrid>
    <p class="mt-12 max-w-2xl text-sm text-muted">{tr('teams.footer')}</p>
  </div>
</GameHubLayout>
