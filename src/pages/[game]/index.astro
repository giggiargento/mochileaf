---
import GameHubLayout from '../../layouts/GameHubLayout.astro';
import PageHeader from '../../components/game/PageHeader.astro';
import ContentGrid from '../../components/game/ContentGrid.astro';
import CharacterCard from '../../components/game/CharacterCard.astro';
import ArticleCard from '../../components/home/ArticleCard.astro';
import AdPlaceholder from '../../components/ui/AdPlaceholder.astro';
import { games, getGame as getLocalizedGame } from '../../data/games';
import { getCharactersByGame } from '../../data/characters';
import { getNewsByGame, getGuidesByGame } from '../../data/articles';
import { getHubCopy } from '../../utils/game-hub';
import Button from '../../components/ui/Button.astro';
import LiveIntelSection from '../../components/content/LiveIntelSection.astro';
import GameHubHero from '../../components/game/GameHubHero.astro';
import { getLiveFeedsForGame } from '../../utils/live-content';
import { usePageLocale } from '../../lib/i18n/use-page-locale';

export function getStaticPaths() {
  return games
    .filter((g) => g.status === 'active')
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game: hubGame } = Astro.props;
const { locale, tr, hub } = usePageLocale(Astro.currentLocale);
const game = getLocalizedGame(hubGame.slug, locale) ?? hubGame;
const hubCopy = getHubCopy(game, locale);
const hubBase = hub(game.slug);
const isAcnh = game.slug === 'animal-crossing-new-horizons';
const featuredCount =
  game.slug === 'neverness-to-everness' || isAcnh ? 6 : 3;
let characters = getCharactersByGame(game.slug);
if (game.slug === 'neverness-to-everness') {
  characters = [...characters].sort((a, b) => {
    if (a.slug === 'lacrimosa') return -1;
    if (b.slug === 'lacrimosa') return 1;
    return a.name.localeCompare(b.name, 'en');
  });
}
characters = characters.slice(0, featuredCount);
const hubArticles = [
  ...(await getNewsByGame(game.slug, locale)),
  ...(await getGuidesByGame(game.slug, locale)),
]
  .sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime())
  .slice(0, 2);
const liveFeeds = getLiveFeedsForGame(game.slug);
---

<GameHubLayout game={game} title={tr('hub.home')}>
  <GameHubHero game={game}>
      <p class="text-xs font-medium uppercase tracking-widest text-accent">
        {game.tagline}
      </p>
      <h1 class="mt-2 font-display text-4xl md:text-5xl text-primary max-w-2xl">
        {tr('hub.welcome', { game: game.name })}
      </h1>
      <p class="mt-4 max-w-xl text-lg text-secondary">{game.description}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href={`${hubBase}/${hubCopy.primaryCta.path}`}>{hubCopy.primaryCta.label}</Button>
        <Button href={`${hubBase}/${hubCopy.secondaryCta.path}`} variant="secondary">
          {hubCopy.secondaryCta.label}
        </Button>
      </div>
  </GameHubHero>

  <section class="pb-12">
    <PageHeader
      title={hubCopy.featuredSectionTitle}
      description={hubCopy.charactersDescription}
    />
    <div class="page-container pt-8 pb-0">
      <ContentGrid columns={3}>
        {characters.map((c) => <CharacterCard character={c} gameSlug={game.slug} />)}
      </ContentGrid>
      <div class="mt-6 text-center">
        <a href={`${hubBase}/characters`} class="cozy-link text-sm font-semibold">
          {tr('hub.viewAll', { list: hubCopy.charactersTitle.toLowerCase() })}
        </a>
      </div>
    </div>
  </section>

  <section class="pb-12 border-t border-default">
    <PageHeader
      title={tr('hub.latest')}
      description={
        game.slug === 'neverness-to-everness' ? tr('hub.latestNte') : undefined
      }
    />
    <div class="page-container pt-8 pb-0">
      <ContentGrid columns={2}>
        {hubArticles.map((a) => <ArticleCard article={a} />)}
      </ContentGrid>
      <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm font-semibold">
        <a href={`${hubBase}/news`} class="cozy-link">
          {tr('hub.allNews')}
        </a>
        <a href={`${hubBase}/guides`} class="cozy-link">
          {tr('hub.allGuides')}
        </a>
        {
          game.slug === 'neverness-to-everness' && (
            <a href={`${hubBase}/teams`} class="cozy-link">
              {tr('hub.teamComps')}
            </a>
          )
        }
        {
          isAcnh && (
            <>
              <a href={`${hubBase}/houses`} class="cozy-link">
                {tr('hub.decorHomes')}
              </a>
              <a href={`${hubBase}/island-tours`} class="cozy-link">
                {tr('hub.islandTours')}
              </a>
            </>
          )
        }
      </div>
    </div>
  </section>

  <LiveIntelSection feeds={liveFeeds} />

  <div class="page-container py-8">
    <AdPlaceholder slot="inline" />
  </div>
</GameHubLayout>
