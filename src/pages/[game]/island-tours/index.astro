---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import ContentGrid from '../../../components/game/ContentGrid.astro';
import IslandTourCard from '../../../components/game/IslandTourCard.astro';
import { games } from '../../../data/games';
import { getIslandToursByGame } from '../../../data/island-tours-acnh';
import { usePageLocale } from '../../../lib/i18n/use-page-locale';
import { t } from '../../../i18n/messages';

export function getStaticPaths() {
  return games
    .filter((g) => g.status === 'active' && getIslandToursByGame(g.slug).length > 0)
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const { locale, tr } = usePageLocale(Astro.currentLocale);
const tours = getIslandToursByGame(game.slug);
---

<GameHubLayout game={game} title={t('nav.islandTours', locale)} description={tr('island.meta', { game: game.name })}>
  <PageHeader title={tr('island.title')} description={tr('island.description')} />
  <div class="page-container-below-header">
    <ContentGrid columns={2}>
      {tours.map((tour) => (
        <IslandTourCard tour={tour} />
      ))}
    </ContentGrid>
    <p class="mt-12 max-w-2xl text-sm text-muted">{tr('island.footer')}</p>
  </div>
</GameHubLayout>
