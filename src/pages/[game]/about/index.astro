---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import { games, getGame } from '../../../data/games';
import { getGameNavForGame } from '../../../data/game-nav';
import type { GameContent } from '../../../content/schemas';
import { displayStringList } from '../../../content/schemas/shared';
import { resolveContentSeo } from '../../../lib/content/seo';
import { usePageLocale } from '../../../lib/i18n/use-page-locale';

export function getStaticPaths() {
  return games
    .filter((g) => g.status === 'active')
    .map((game) => ({ params: { game: game.slug }, props: { game: getGame(game.slug)! } }));
}

const { game } = Astro.props;
const { locale, tr, hub } = usePageLocale(Astro.currentLocale);
const hubData = game as GameContent;
const seo = resolveContentSeo(hubData.seo, {
  title: tr('aboutHub.title', { game: game.name }),
  description: hubData.about ?? game.description,
});
const navItems = getGameNavForGame(game, locale).filter((item) => item.href !== hub(game.slug));
const isStardew = game.slug === 'stardew-valley';
---

<GameHubLayout game={game} title={seo.title} description={seo.description}>
  <PageHeader title={tr('aboutHub.title', { game: game.name })} description={game.tagline} />
  <div class="page-container-below-header">
    <article class="prose-cozy">
      <p>{hubData.about ?? game.description}</p>
      <p>{tr('aboutHub.intro')}</p>
      {
        isStardew && (
          <p>
            {tr('aboutHub.stardewBefore')}{' '}
            <a href={hub(game.slug, 'mods')} class="cozy-link">{tr('aboutHub.modsLink')}</a>{' '}
            {tr('aboutHub.stardewAfter')}
          </p>
        )
      }

      {
        displayStringList(hubData.genres).length > 0 && (
          <>
            <h2 class="font-display text-xl text-primary mt-8">{tr('aboutHub.genres')}</h2>
            <ul class="list-disc pl-6 space-y-2 mt-4">
              {displayStringList(hubData.genres).map((genre) => <li>{genre}</li>)}
            </ul>
          </>
        )
      }

      {
        displayStringList(hubData.platforms).length > 0 && (
          <>
            <h2 class="font-display text-xl text-primary mt-8">{tr('aboutHub.platforms')}</h2>
            <ul class="list-disc pl-6 space-y-2 mt-4">
              {displayStringList(hubData.platforms).map((platform) => <li>{platform}</li>)}
            </ul>
          </>
        )
      }

      {
        displayStringList(hubData.cozyMechanics).length > 0 && (
          <>
            <h2 class="font-display text-xl text-primary mt-8">{tr('aboutHub.cozyMechanics')}</h2>
            <ul class="list-disc pl-6 space-y-2 mt-4">
              {displayStringList(hubData.cozyMechanics).map((item) => <li>{item}</li>)}
            </ul>
          </>
        )
      }

      {
        displayStringList(hubData.beginnerTips).length > 0 && (
          <>
            <h2 class="font-display text-xl text-primary mt-8">{tr('aboutHub.beginnerTips')}</h2>
            <ul class="list-disc pl-6 space-y-2 mt-4">
              {displayStringList(hubData.beginnerTips).map((tip) => <li>{tip}</li>)}
            </ul>
          </>
        )
      }

      {
        displayStringList(hubData.similarGames).length > 0 && (
          <>
            <h2 class="font-display text-xl text-primary mt-8">{tr('aboutHub.similarGames')}</h2>
            <ul class="list-disc pl-6 space-y-2 mt-4">
              {displayStringList(hubData.similarGames).map((title) => <li>{title}</li>)}
            </ul>
          </>
        )
      }

      <h2 class="font-display text-xl text-primary mt-8">{tr('aboutHub.findHere')}</h2>
      <ul class="list-disc pl-6 space-y-2 mt-4">
        {
          navItems.map((item) => (
            <li>
              <a href={item.href} class="cozy-link">{item.label}</a>
            </li>
          ))
        }
      </ul>
    </article>
  </div>
</GameHubLayout>
