---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import ContentGrid from '../../../components/game/ContentGrid.astro';
import BuildCard from '../../../components/game/BuildCard.astro';
import { games } from '../../../data/games';
import { getBuildsByGame } from '../../../data/builds';

export function getStaticPaths() {
  return games
    .filter((g) => g.status === 'active')
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const builds = getBuildsByGame(game.slug);
const isStardew = game.slug === 'stardew-valley';
const isNte = game.slug === 'neverness-to-everness';
const isAcnh = game.slug === 'animal-crossing-new-horizons';
---

<GameHubLayout game={game} title="Builds">
  <PageHeader
    title="Builds"
    description="Relaxed loadouts and thoughtful setups — no sweaty meta required."
  />
  <div class="page-container-below-header">
    {
      isStardew ? (
        <div class="prose-cozy py-16">
          <p>
            Stardew Valley does not use character builds or loadouts. For PC enhancements, visit our
            <a href={`/${game.slug}/mods`} class="cozy-link">recommended mods</a> page instead.
          </p>
        </div>
      ) : isNte ? (
        <div class="prose-cozy py-16">
          <p>
            Per-character weapon and Arc Disc builds are on the way. For now, browse recommended{' '}
            <a href={`/${game.slug}/teams`} class="cozy-link">team comps</a> and character profiles.
          </p>
        </div>
      ) : isAcnh ? (
        <div class="prose-cozy py-16">
          <p>
            Animal Crossing hubs focus on villagers and decorating. Visit{' '}
            <a href={`/${game.slug}/characters`} class="cozy-link">villagers</a>,{' '}
            <a href={`/${game.slug}/houses`} class="cozy-link">homes</a>, or{' '}
            <a href={`/${game.slug}/items`} class="cozy-link">items</a> instead.
          </p>
        </div>
      ) : builds.length > 0 ? (
        <ContentGrid columns={2}>
          {builds.map((b) => (
            <BuildCard build={b} />
          ))}
        </ContentGrid>
      ) : (
        <p class="prose-cozy text-center py-16">Build guides are being written with care. Check back soon.</p>
      )
    }
  </div>
</GameHubLayout>
