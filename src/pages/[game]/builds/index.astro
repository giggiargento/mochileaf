---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import ContentGrid from '../../../components/game/ContentGrid.astro';
import BuildCard from '../../../components/game/BuildCard.astro';
import { games } from '../../../data/games';
import { getBuildsByGame } from '../../../data/builds';
import { usePageLocale } from '../../../lib/i18n/use-page-locale';
import { t } from '../../../i18n/messages';

export function getStaticPaths() {
  return games
    .filter((g) => g.status === 'active')
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const { locale, tr, hub } = usePageLocale(Astro.currentLocale);
const builds = getBuildsByGame(game.slug);
const isStardew = game.slug === 'stardew-valley';
const isNte = game.slug === 'neverness-to-everness';
const isAcnh = game.slug === 'animal-crossing-new-horizons';
---

<GameHubLayout game={game} title={t('nav.builds', locale)}>
  <PageHeader title={tr('builds.title')} description={tr('builds.description')} />
  <div class="page-container-below-header">
    {
      isStardew ? (
        <div class="prose-cozy py-16">
          <p>
            {tr('builds.stardewBefore')}{' '}
            <a href={hub(game.slug, 'mods')} class="cozy-link">{tr('builds.stardewLink')}</a>{' '}
            {tr('builds.stardewAfter')}
          </p>
        </div>
      ) : isNte ? (
        <div class="prose-cozy py-16">
          <p>
            {tr('builds.nteBefore')}{' '}
            <a href={hub(game.slug, 'teams')} class="cozy-link">{tr('builds.nteTeams')}</a>{' '}
            {tr('builds.nteAfter')}
          </p>
        </div>
      ) : isAcnh ? (
        <div class="prose-cozy py-16">
          <p>
            {tr('builds.acnhBefore')}{' '}
            <a href={hub(game.slug, 'characters')} class="cozy-link">{tr('builds.acnhVillagers')}</a>,{' '}
            <a href={hub(game.slug, 'houses')} class="cozy-link">{tr('builds.acnhHomes')}</a>, or{' '}
            <a href={hub(game.slug, 'items')} class="cozy-link">{tr('builds.acnhItems')}</a>{' '}
            {tr('builds.acnhAfter')}
          </p>
        </div>
      ) : builds.length > 0 ? (
        <ContentGrid columns={2}>
          {builds.map((b) => (
            <BuildCard build={b} />
          ))}
        </ContentGrid>
      ) : (
        <p class="prose-cozy text-center py-16">{tr('builds.empty')}</p>
      )
    }
  </div>
</GameHubLayout>
