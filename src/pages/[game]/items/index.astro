---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import ItemDirectory from '../../../components/game/acnh/ItemDirectory.astro';
import { games } from '../../../data/games';
import { hasAcnhItems } from '../../../data/items-acnh';

export function getStaticPaths() {
  return games
    .filter((g) => g.status === 'active' && hasAcnhItems(g.slug))
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const isAcnh = game.slug === 'animal-crossing-new-horizons';
---

<GameHubLayout
  game={game}
  title="Items"
  description={`Browse furniture and interior items in ${game.name} — by type, with icons from Nookipedia.`}
>
  <PageHeader
    title="Items & decor"
    description="Housewares, wallpaper, rugs, and more — grouped like Nookipedia. Search within each tab to find something fast."
  />
  <div class="page-container-below-header">
    {isAcnh && <ItemDirectory game={game} />}
  </div>
</GameHubLayout>
