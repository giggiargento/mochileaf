---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import ArticleDetail from '../../../components/article/ArticleDetail.astro';
import { getGame } from '../../../data/games';
import { articleSlugFromId, loadArticleEntries, renderArticleForLocale, articleSeoForLocale } from '../../../data/articles';
import { isGuideCategory } from '../../../utils/article-routes';
import { usePageLocale } from '../../../lib/i18n/use-page-locale';
import { t } from '../../../i18n/messages';

export async function getStaticPaths() {
  const entries = await loadArticleEntries();
  return entries
    .filter((entry) => entry.data.gameSlug && isGuideCategory(entry.data.category))
    .map((entry) => {
      const slug = articleSlugFromId(entry.id);
      const game = getGame(entry.data.gameSlug!)!;
      return {
        params: { game: entry.data.gameSlug, slug },
        props: { slug, gameSlug: entry.data.gameSlug, game },
      };
    });
}

const { slug, game } = Astro.props;
const { locale } = usePageLocale(Astro.currentLocale);
const rendered = await renderArticleForLocale(slug, locale);
if (!rendered) {
  return Astro.redirect(`/${game.slug}/guides`, 302);
}
const { article, entry, html, Content } = rendered;
const seo = articleSeoForLocale(entry, article, locale);
---

<GameHubLayout game={game} title={seo.title} description={seo.description}>
  <PageHeader badge={t('badge.guide', locale)} title={article.title} description={article.excerpt} />
  <div class="page-container-below-header">
    <ArticleDetail
      article={article}
      game={game}
      locale={locale}
      coverImage={entry.data.coverImage}
      coverCaption={article.coverCaption ?? entry.data.coverCaption}
    >
      {
        html ? (
          <div class="prose-cozy space-y-6" set:html={html} />
        ) : (
          Content && (
            <div class="prose-cozy space-y-6">
              <Content />
            </div>
          )
        )
      }
    </ArticleDetail>
  </div>
</GameHubLayout>
