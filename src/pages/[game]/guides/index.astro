---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import ArticleCard from '../../../components/home/ArticleCard.astro';
import ContentGrid from '../../../components/game/ContentGrid.astro';
import { games } from '../../../data/games';
import { getGuidesByGame } from '../../../data/articles';

export function getStaticPaths() {
  return games
    .filter((g) => g.status === 'active')
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const guides = getGuidesByGame(game.slug);
---

<GameHubLayout game={game} title="Guides">
  <PageHeader
    title="Guides"
    description="Step-by-step walkthroughs with editorial calm — take your time."
  />
  <div class="page-container-below-header">
    {guides.length > 0 ? (
      <ContentGrid columns={2}>
        {guides.map((a) => <ArticleCard article={a} />)}
      </ContentGrid>
    ) : (
      <p class="prose-cozy text-center py-16">Guides are being illustrated. Check back soon.</p>
    )}
  </div>
</GameHubLayout>
