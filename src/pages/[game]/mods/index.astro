---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import ContentGrid from '../../../components/game/ContentGrid.astro';
import ModCard from '../../../components/game/ModCard.astro';
import { games } from '../../../data/games';
import { getModsByGame } from '../../../data/mods';
import { usePageLocale } from '../../../lib/i18n/use-page-locale';
import { t } from '../../../i18n/messages';

export function getStaticPaths() {
  return games
    .filter((g) => g.status === 'active')
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const { locale, tr } = usePageLocale(Astro.currentLocale);
const gameMods = getModsByGame(game.slug);
const isStardew = game.slug === 'stardew-valley';
---

<GameHubLayout
  game={game}
  title={t('nav.mods', locale)}
  description={isStardew ? tr('mods.metaStardew') : tr('mods.metaDefault', { game: game.name })}
>
  <PageHeader
    title={isStardew ? tr('mods.titleStardew') : tr('mods.title')}
    description={isStardew ? tr('mods.descriptionStardew') : tr('mods.descriptionDefault')}
  />
  <div class="page-container-below-header">
    {
      gameMods.length > 0 ? (
        <ContentGrid columns={2}>
          {gameMods.map((mod) => (
            <ModCard mod={mod} />
          ))}
        </ContentGrid>
      ) : (
        <p class="prose-cozy text-center py-16">{tr('mods.empty')}</p>
      )
    }
  </div>
</GameHubLayout>
