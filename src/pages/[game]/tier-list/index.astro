---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import TierRow from '../../../components/game/TierRow.astro';
import { games } from '../../../data/games';
import { getTierListForGame } from '../../../data/tier-list';

export function getStaticPaths() {
  return games
    .filter((g) => g.status === 'active' && g.slug !== 'neverness-to-everness')
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const tiers = getTierListForGame(game.slug);
---

<GameHubLayout game={game} title="Tier List">
  <PageHeader
    title="Tier list"
    description="A gentle ranking for cozy strategists — updated with community warmth, not rage."
  />
  <div class="page-container-below-header space-y-4">
    {tiers.map((entry) => <TierRow entry={entry} gameSlug={game.slug} />)}
    {
      game.slug !== 'neverness-to-everness' && (
        <p class="text-sm text-muted mt-8">
          Tier lists are placeholder data. Connect your API or CMS for live rankings.
        </p>
      )
    }
    {
      game.slug === 'neverness-to-everness' && (
        <p class="text-sm text-muted mt-8">
          Rankings favor story comfort and F2P value — not speedrun leaderboards. Patch shifts will be
          noted in hub news.
        </p>
      )
    }
  </div>
</GameHubLayout>
