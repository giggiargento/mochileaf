---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import HouseCard from '../../../components/game/acnh/HouseCard.astro';
import { games } from '../../../data/games';
import { acnhVillagers } from '../../../data/characters-acnh';

export function getStaticPaths() {
  return games
    .filter((g) => g.slug === 'animal-crossing-new-horizons' && g.status === 'active')
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const withHouses = acnhVillagers.filter((v) => v.houseDescription);
---

<GameHubLayout
  game={game}
  title="Villager homes"
  description={`Default home styles and interiors for popular ${game.shortName ?? 'ACNH'} villagers.`}
>
  <PageHeader
    title="Villager homes"
    description="Exterior themes and default interior vibes — tap a card for full house notes on each villager’s profile."
  />
  <div class="page-container-below-header space-y-4">
    {withHouses.map((villager) => (
      <HouseCard villager={villager} gameSlug={game.slug} />
    ))}
  </div>
</GameHubLayout>
