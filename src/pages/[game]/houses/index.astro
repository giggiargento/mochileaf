---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import DecorInspirationGallery from '../../../components/game/acnh/DecorInspirationGallery.astro';
import Button from '../../../components/ui/Button.astro';
import Icon from '../../../components/ui/Icon.astro';
import { games } from '../../../data/games';
import {
  acnhDecorInspiration,
  acnhPinterestBoardUrl,
  getAcnhHomesGallery,
} from '../../../data/decor-inspiration-acnh';

export function getStaticPaths() {
  return games
    .filter((g) => g.slug === 'animal-crossing-new-horizons' && g.status === 'active')
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const galleryItems = getAcnhHomesGallery();
const hasMoreOnPinterest = acnhDecorInspiration.length > galleryItems.length;
---

<GameHubLayout
  game={game}
  title="Homes"
  description="Interior decor inspiration for Animal Crossing: New Horizons — cozy room ideas and moodboard layouts."
>
  <PageHeader
    title="Homes & decor inspiration"
    description="A calm moodboard of interior ideas — cottage corners, minimalist studies, and soft lighting setups to bookmark before you open the catalog."
  />
  <div class="page-container-below-header">
    <DecorInspirationGallery items={galleryItems} showEmptyHelp emptyBoardKey="homes" />
    {
      galleryItems.length > 0 && acnhPinterestBoardUrl && (
        <div class="mt-10 flex flex-col items-center gap-3 text-center">
          {
            hasMoreOnPinterest && (
              <p class="max-w-md text-sm text-muted">
                Showing {galleryItems.length} ideas here — the full moodboard has more on Pinterest.
              </p>
            )
          }
          <Button
            href={acnhPinterestBoardUrl}
            variant="secondary"
            size="lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Icon name="arrow-square-out" size={18} />
            See more on Pinterest
          </Button>
        </div>
      )
    }
    <p class="mt-10 max-w-2xl text-sm text-muted">
      Looking for each villager’s default interior notes?
      <a href={`/${game.slug}/characters`} class="cozy-link">
        Browse villagers →
      </a>
    </p>
  </div>
</GameHubLayout>
