---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import ContentGrid from '../../../components/game/ContentGrid.astro';
import CharacterCard from '../../../components/game/CharacterCard.astro';
import VillagerDirectory from '../../../components/game/acnh/VillagerDirectory.astro';
import { games } from '../../../data/games';
import { getCharactersByGame } from '../../../data/characters';
import { getGame } from '../../../data/games';
import { getHubCopy } from '../../../utils/game-hub';
import { resolveLocale } from '../../../i18n/locale';
import { t } from '../../../i18n/messages';

export function getStaticPaths() {
  return games
    .filter((g) => g.status === 'active')
    .map((game) => ({ params: { game: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const characters = getCharactersByGame(game.slug, locale);
const localizedGame = getGame(game.slug, locale) ?? game;
const hubCopy = getHubCopy(game, locale);
const isAcnh = game.slug === 'animal-crossing-new-horizons';
---

<GameHubLayout
  game={game}
  title={hubCopy.charactersTitle}
  description={`${hubCopy.charactersTitle} in ${localizedGame.name} — profiles and cozy summaries.`}
>
  <PageHeader title={hubCopy.charactersTitle} description={hubCopy.charactersDescription} />
  <div class="page-container-below-header">
    {
      isAcnh ? (
        <VillagerDirectory game={game} locale={locale} />
      ) : characters.length > 0 ? (
        <ContentGrid columns={3}>
          {characters.map((c) => (
            <CharacterCard character={c} gameSlug={game.slug} />
          ))}
        </ContentGrid>
      ) : (
        <p class="prose-cozy text-center py-16">{t('character.emptyList', locale)}</p>
      )
    }
  </div>
</GameHubLayout>
