---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import Badge from '../../../components/ui/Badge.astro';
import Button from '../../../components/ui/Button.astro';
import { games } from '../../../data/games';
import { characters, getCharacter } from '../../../data/characters';

export function getStaticPaths() {
  return characters
    .filter((character) => {
      const game = games.find((g) => g.slug === character.gameSlug);
      return game && game.status === 'active';
    })
    .map((character) => {
      const game = games.find((g) => g.slug === character.gameSlug)!;
      return {
        params: { game: character.gameSlug, slug: character.slug },
        props: { game, character },
      };
    });
}

const { game, character } = Astro.props;
---

<GameHubLayout game={game} title={character.name}>
  <article class="page-container-below-header max-w-4xl">
    <a href={`/${game.slug}/characters`} class="cozy-link text-sm font-medium">← All characters</a>
    <div class="mt-8 grid gap-10 md:grid-cols-2">
      <div class="aspect-square rounded-[var(--radius-card)] bg-gradient-to-br from-sage-100 to-mist-100 flex items-center justify-center text-8xl dark:from-sage-500/20 dark:to-mist-300/10" aria-hidden="true">
        🌿
      </div>
      <div>
        <div class="flex flex-wrap gap-2 mb-4">
          {character.tier && <Badge variant="sage">Tier {character.tier}</Badge>}
          {character.element && <Badge variant="mist">{character.element}</Badge>}
        </div>
        <h1 class="font-display text-4xl text-primary">{character.name}</h1>
        <p class="mt-2 text-lg font-medium text-accent">{character.role}</p>
        <p class="mt-6 prose-cozy">{character.description}</p>
        <div class="mt-8 flex gap-3">
          <Button href={`/${game.slug}/builds`}>View builds</Button>
          <Button href={`/${game.slug}/tier-list`} variant="secondary">Tier list</Button>
        </div>
      </div>
    </div>
  </article>
</GameHubLayout>
