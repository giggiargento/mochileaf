---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import Badge from '../../../components/ui/Badge.astro';
import Button from '../../../components/ui/Button.astro';
import Icon from '../../../components/ui/Icon.astro';
import { getCharacterBySlug } from '../../../data/characters';
import { routableCharacters, routableGames } from '../../../lib/content/registry';
import { getHubCopy } from '../../../utils/game-hub';
import DecorInspirationGallery from '../../../components/game/acnh/DecorInspirationGallery.astro';
import VillagerDetailSections from '../../../components/game/acnh/VillagerDetailSections.astro';
import { getAcnhDecorForCharacter } from '../../../data/character-decor-acnh';
import { villagerPortrait } from '../../../data/characters-acnh';
import { acnhPinterestBoards } from '../../../data/pinterest-boards-acnh';
import { getNteCharacterGuide } from '../../../data/nte-character-guides';
import { getNteBondGiftsForCharacter } from '../../../data/nte-bond-gifts';
import NteBondGiftsSection from '../../../components/game/NteBondGiftsSection.astro';
import { resolveContentSeo } from '../../../lib/content/seo';
import { localePath, resolveLocale } from '../../../i18n/locale';
import { localizeCharacterSeo } from '../../../lib/i18n/content';
import { t } from '../../../i18n/messages';

export function getStaticPaths() {
  return routableCharacters.map((character) => {
      const game = routableGames.find((g) => g.slug === character.gameSlug)!;
      return {
        params: { game: character.gameSlug, slug: character.slug },
        props: { game, character },
      };
    });
}

const { game, character: rawCharacter } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const character = getCharacterBySlug(rawCharacter.slug, locale) ?? rawCharacter;
const hubCopy = getHubCopy(game, locale);
const charactersListHref = localePath(`/${game.slug}/characters`, locale);
const isAcnh = game.slug === 'animal-crossing-new-horizons';
const isNte = game.slug === 'neverness-to-everness';
const acnhDetails = isAcnh ? character.acnh : undefined;
const nteGuide = isNte ? getNteCharacterGuide(character, locale) : undefined;
const nteBondGifts = isNte ? getNteBondGiftsForCharacter(character.slug) : undefined;
const portraitAlt = `${character.name} — ${character.role} in ${game.name}`;
const listLabel = hubCopy.charactersTitle.toLowerCase();
const characterSeo = localizeCharacterSeo(
  resolveContentSeo(character.seo, {
    title: character.name,
    description: character.description,
  }),
  character.slug,
  locale,
);

function personalityLabel(value: string | undefined): string | undefined {
  if (!value) return undefined;
  const key = `acnh.personality.${value.replace(/\s+/g, '')}`;
  const translated = t(key, locale);
  return translated !== key ? translated : value;
}
const characterDecor = isAcnh ? getAcnhDecorForCharacter(character.slug) : [];
const characterPinterestBoard =
  isAcnh && character.slug in acnhPinterestBoards
    ? acnhPinterestBoards[character.slug as keyof typeof acnhPinterestBoards]
    : undefined;
const portraitSrc =
  isAcnh && character.image ? villagerPortrait(character.slug, 256) : character.image;
const nteElementIconPath: Record<string, string> = {
  Cosmos: '/images/games/neverness-to-everness/icons/Cosmos.webp',
  Anima: '/images/games/neverness-to-everness/icons/Anima.webp',
  Incantation: '/images/games/neverness-to-everness/icons/Incantation.webp',
  Chaos: '/images/games/neverness-to-everness/icons/Chaos.webp',
  Psyche: '/images/games/neverness-to-everness/icons/Psyche.webp',
  Lakshana: '/images/games/neverness-to-everness/icons/Lakshana.webp',
};

const villagerInfoRows =
  acnhDetails?.villagerInfo
    ? ([
        { label: t('character.field.birthday', locale), value: acnhDetails.villagerInfo.birthday },
        { label: t('character.field.starSign', locale), value: acnhDetails.villagerInfo.starSign },
        {
          label: t('character.field.personality', locale),
          value: personalityLabel(acnhDetails.villagerInfo.personality),
        },
        { label: t('character.field.subPersonality', locale), value: acnhDetails.villagerInfo.subPersonality },
        {
          label: t('character.field.catchphrase', locale),
          value: acnhDetails.villagerInfo.catchphrase
            ? `“${acnhDetails.villagerInfo.catchphrase}”`
            : undefined,
        },
        {
          label: t('character.field.quote', locale),
          value: acnhDetails.villagerInfo.quote ? `“${acnhDetails.villagerInfo.quote}”` : undefined,
        },
        { label: t('character.field.gender', locale), value: acnhDetails.villagerInfo.gender },
        { label: t('character.field.clothing', locale), value: acnhDetails.villagerInfo.defaultClothing },
        { label: t('character.field.hobby', locale), value: acnhDetails.villagerInfo.hobby },
        {
          label: t('character.field.styles', locale),
          value: acnhDetails.villagerInfo.favoriteStyles?.length
            ? acnhDetails.villagerInfo.favoriteStyles.join(', ')
            : undefined,
        },
        {
          label: t('character.field.colors', locale),
          value: acnhDetails.villagerInfo.favoriteColors?.length
            ? acnhDetails.villagerInfo.favoriteColors.join(', ')
            : undefined,
        },
        { label: t('character.field.bag', locale), value: acnhDetails.villagerInfo.bag },
        { label: t('character.field.snack', locale), value: acnhDetails.villagerInfo.food },
        { label: t('character.field.drink', locale), value: acnhDetails.villagerInfo.drink },
      ] as { label: string; value?: string }[]).filter((row) => row.value)
    : [];
---

<GameHubLayout game={game} title={characterSeo.title} description={characterSeo.description}>
  <div class="page-container-below-header">
    <a href={charactersListHref} class="cozy-link text-sm font-medium" data-astro-reload>
      ← {t('character.backAll', locale, { list: listLabel })}
    </a>
    <div class="character-detail-grid mt-8">
      <div class="min-w-0 space-y-4">
      <div class="character-portrait-frame min-w-0">
        <div class="character-portrait-inner">
        {
          character.image ? (
            <img
              src={portraitSrc}
              alt={portraitAlt}
              width={320}
              height={400}
              class="character-portrait-img pixel-portrait"
              loading="eager"
              decoding="async"
            />
          ) : (
            <div class="character-portrait-placeholder" aria-hidden="true">
              <Icon name="user-circle" size={72} />
            </div>
          )
        }
        </div>
      </div>
      {villagerInfoRows.length > 0 && (
        <div class="cozy-table-wrap">
          <table class="cozy-table">
            <tbody>
              {villagerInfoRows.map((row) => (
                <tr>
                  <th scope="row">{row.label}</th>
                  <td>{row.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
      </div>
      <div class="character-detail-panel min-w-0">
        <div class="character-detail-intro">
          <div class="mb-4 flex flex-wrap gap-2">
            {character.rarity && <Badge variant="blossom">{character.rarity}-rank</Badge>}
            {character.tier && (
              <Badge variant="sage">{t('character.tier', locale, { tier: character.tier })}</Badge>
            )}
            {character.personality && (
              <Badge variant="mist">{personalityLabel(character.personality)}</Badge>
            )}
            {character.species && <Badge variant="lavender">{character.species}</Badge>}
            {character.element && <Badge variant="mist">{character.element}</Badge>}
          </div>
          <h1 class="font-display text-4xl text-primary flex items-center gap-3">
            {
              isNte && character.element && nteElementIconPath[character.element] && (
                <img
                  src={nteElementIconPath[character.element]}
                  alt={character.element}
                  width={36}
                  height={36}
                  class="h-9 w-9 rounded-full border border-default object-cover"
                  loading="lazy"
                  decoding="async"
                />
              )
            }
            <span>{character.name}</span>
          </h1>
          <p class="mt-2 text-lg font-medium text-accent">{character.role}</p>
          <p class="mt-6 prose-cozy">{character.description}</p>

          {
            isAcnh && (
              <div class="mt-8">
                <h2 class="font-display text-xl text-primary">{t('character.explore.title', locale)}</h2>
                <p class="mt-2 text-base leading-relaxed text-secondary">
                  {t('character.explore.description', locale)}
                </p>
                <div class="mt-4 flex flex-wrap gap-2">
                  <a
                    href="#house"
                    class="inline-flex items-center justify-center rounded-[var(--radius-pill)] bg-sage-500 px-4 py-2 text-sm font-semibold text-white shadow-soft transition-colors hover:bg-sage-600"
                  >
                    {t('character.explore.house', locale)}
                  </a>
                  {
                    characterDecor.length > 0 && (
                      <a
                        href="#decor"
                        class="inline-flex items-center justify-center rounded-[var(--radius-pill)] border border-default bg-page px-4 py-2 text-sm font-semibold text-primary transition-colors hover:border-sage-300 hover:text-accent"
                      >
                        {t('character.explore.decor', locale)}
                      </a>
                    )
                  }
                </div>
              </div>
            )
          }

          {
            acnhDetails && (acnhDetails.appearance || acnhDetails.personality) && (
              <section class="mt-8" aria-label={t('character.characteristics', locale)}>
                <h2 class="section-title mb-4">{t('character.characteristics', locale)}</h2>
                <div class="prose-cozy max-w-3xl space-y-4">
                  {acnhDetails.appearance && (
                    <div>
                      <h3 class="text-sm font-semibold uppercase tracking-wide text-muted">
                        {t('character.appearance', locale)}
                      </h3>
                      <p class="mt-2">{acnhDetails.appearance}</p>
                    </div>
                  )}
                  {acnhDetails.personality && (
                    <div>
                      <h3 class="text-sm font-semibold uppercase tracking-wide text-muted">
                        {t('character.personalitySection', locale)}
                      </h3>
                      <p class="mt-2">{acnhDetails.personality}</p>
                    </div>
                  )}
                </div>
              </section>
            )
          }
        </div>
      </div>
    </div>

    {
      nteGuide && (
        <section class="mt-16 space-y-8" aria-label={t('character.buildGuide', locale)}>
          <div>
            <h2 class="section-title mb-2">{t('character.buildGuide', locale)}</h2>
            <p class="text-sm text-secondary">{nteGuide.buildSummary}</p>
          </div>

          <div class="grid gap-6 lg:grid-cols-2">
            <article class="cozy-card p-6">
              <h3 class="font-display text-xl text-primary">{t('character.recommendedDisks', locale)}</h3>
              <ul class="mt-4 space-y-3">
                {nteGuide.diskSets.map((disk) => (
                  <li class="flex items-center gap-3 rounded-xl border border-default bg-card p-3">
                    {disk.image && (
                      <img
                        src={disk.image}
                        alt={disk.name}
                        width={32}
                        height={32}
                        class="h-8 w-8 rounded-full border border-default object-cover"
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                    <div class="min-w-0">
                      <p class="text-sm font-semibold text-primary">{disk.name}</p>
                      {disk.note && <p class="text-xs text-secondary">{disk.note}</p>}
                    </div>
                  </li>
                ))}
              </ul>
            </article>

            <article class="cozy-card p-6">
              <h3 class="font-display text-xl text-primary">{t('character.recommendedModules', locale)}</h3>
              <ul class="mt-4 space-y-3">
                {nteGuide.modules.map((module) => (
                  <li class="flex items-center gap-3 rounded-xl border border-default bg-card p-3">
                    {module.image && (
                      <img
                        src={module.image}
                        alt={module.name}
                        width={32}
                        height={32}
                        class="h-8 w-8 rounded-full border border-default object-cover"
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                    <div class="min-w-0">
                      <p class="text-sm font-semibold text-primary">{module.name}</p>
                      {module.note && <p class="text-xs text-secondary">{module.note}</p>}
                    </div>
                  </li>
                ))}
              </ul>
            </article>
          </div>

          <div class="grid gap-6 lg:grid-cols-2">
            <article class="cozy-card p-6">
              <h3 class="font-display text-xl text-primary">{t('character.skillPriority', locale)}</h3>
              <ol class="mt-4 space-y-2">
                {nteGuide.skillPriority.map((skill, i) => (
                  <li class="flex min-h-[80px] flex-col justify-center rounded-xl border border-default bg-card p-3">
                    <div class="flex items-center gap-3">
                    <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-muted text-xs font-semibold text-primary">
                      {i + 1}
                    </span>
                      <p class="text-sm font-semibold text-primary">{skill.skill}</p>
                    </div>
                    <p class="mt-1 text-xs text-secondary">{skill.scales}</p>
                  </li>
                ))}
              </ol>
            </article>

            <article class="cozy-card p-6">
              <h3 class="font-display text-xl text-primary">{t('character.farming', locale)}</h3>
              <ul class="mt-4 space-y-3">
                {nteGuide.farming.map((item) => (
                  <li class="rounded-xl border border-default bg-card p-3">
                    <p class="flex flex-wrap items-baseline gap-x-1.5 gap-y-0.5 text-sm">
                      <span class="font-semibold text-primary">{item.name}</span>
                      <span class="text-xs text-secondary">- {item.purpose}</span>
                    </p>
                    <p class="mt-2 inline-flex items-center gap-1.5 text-xs font-medium text-accent">
                      <Icon name="map-pin" size={12} />
                      <span>{t('character.where', locale, { location: item.location })}</span>
                    </p>
                    {item.tip && (
                      <p class="mt-1 inline-flex items-start gap-1.5 text-xs text-muted">
                        <Icon name="lightbulb" size={12} class="mt-0.5" />
                        <span>{t('character.tip', locale, { tip: item.tip })}</span>
                      </p>
                    )}
                  </li>
                ))}
              </ul>
            </article>
          </div>
        </section>
      )
    }

    {nteBondGifts && <NteBondGiftsSection profile={nteBondGifts} locale={locale} />}

    {acnhDetails && (
      <VillagerDetailSections character={character} details={acnhDetails} locale={locale} />
    )}

    {
      characterDecor.length > 0 && (
        <section class="mt-16" id="decor">
          <h2 class="font-display text-2xl text-primary">
            {t('character.decorTitle', locale, { name: character.name })}
          </h2>
        <p class="mt-2 max-w-2xl text-sm text-secondary">
          {t('character.decorDescription', locale)}
        </p>
        <div class="mt-8">
          <DecorInspirationGallery items={characterDecor} emptyBoardKey={character.slug in acnhPinterestBoards ? (character.slug as keyof typeof acnhPinterestBoards) : 'homes'} />
        </div>
        {
          characterPinterestBoard && (
            <div class="mt-10 flex flex-col items-center gap-3 text-center">
              <p class="max-w-md text-sm text-muted">
                {t('character.decorMore', locale, { count: String(characterDecor.length) })}
              </p>
              <Button
                href={characterPinterestBoard}
                variant="secondary"
                size="lg"
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon name="arrow-square-out" size={18} />
                {t('character.pinterestCta', locale)}
              </Button>
            </div>
          )
        }
        </section>
      )
    }
  </div>
</GameHubLayout>
