---
import GameHubLayout from '../../../layouts/GameHubLayout.astro';
import PageHeader from '../../../components/game/PageHeader.astro';
import ArticleDetail from '../../../components/article/ArticleDetail.astro';
import { getGame } from '../../../data/games';
import { getArticleEntry, loadArticleEntries } from '../../../data/articles';
import { isNewsCategory } from '../../../utils/article-routes';
import { render } from 'astro:content';
import { resolveContentSeo } from '../../../lib/content/seo';

export async function getStaticPaths() {
  const entries = await loadArticleEntries();
  return entries
    .filter((entry) => entry.data.gameSlug && isNewsCategory(entry.data.category))
    .map((entry) => {
      const slug = entry.id.replace(/\.md$/, '');
      const game = getGame(entry.data.gameSlug!)!;
      const article = {
        slug,
        title: entry.data.title,
        excerpt: entry.data.excerpt,
        category: entry.data.category,
        gameSlug: entry.data.gameSlug,
        publishedAt: entry.data.publishedAt,
        readTime: entry.data.readTime,
        featured: entry.data.featured,
        trending: entry.data.trending,
      };
      return {
        params: { game: entry.data.gameSlug, slug },
        props: { article, game, entryId: entry.id },
      };
    });
}

const { article, game, entryId } = Astro.props;
const entry = await getArticleEntry(article.slug);
if (!entry) throw new Error(`Missing article entry: ${entryId}`);
const { Content } = await render(entry);
const seo = resolveContentSeo(entry.data.seo, {
  title: article.title,
  description: article.excerpt,
});
const badge = article.category === 'update' ? 'Update' : 'News';
---

<GameHubLayout game={game} title={seo.title} description={seo.description}>
  <PageHeader badge={badge} title={article.title} description={article.excerpt} />
  <div class="page-container-below-header">
    <ArticleDetail article={article} game={game}>
      <Content />
    </ArticleDetail>
  </div>
</GameHubLayout>
