---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import MobileNav from '../components/layout/MobileNav.astro';
import Footer from '../components/layout/Footer.astro';
import ThemeToggle from '../components/ui/ThemeToggle.astro';
import { globalNav } from '../utils/navigation';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description} ambient="home">
  <Sidebar items={globalNav} subtitle="Cozy Gaming" title="Mochileaf">
    <div slot="footer" class="space-y-3">
      <ThemeToggle />
      <p class="text-xs text-ink-300 dark:text-ink-400">Soft fantasy · Peaceful play</p>
    </div>
  </Sidebar>

  <MobileNav items={globalNav} title="Mochileaf" />

  <div class="lg:pl-64">
    <header class="hidden lg:flex items-center justify-end gap-4 px-8 py-4 border-b border-cream-200/60 dark:border-ink-700/40">
      <ThemeToggle />
    </header>
    <main>
      <slot />
    </main>
    <Footer />
  </div>
</BaseLayout>
