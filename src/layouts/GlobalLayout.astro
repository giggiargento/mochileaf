---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import MobileNav from '../components/layout/MobileNav.astro';
import Footer from '../components/layout/Footer.astro';
import ThemeToggle from '../components/ui/ThemeToggle.astro';
import { globalNav } from '../utils/navigation';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description} ambient="home">
  <Sidebar items={globalNav}>
    <div slot="footer" class="space-y-3">
      <ThemeToggle />
      <p class="text-xs text-muted">Soft fantasy · Peaceful play</p>
    </div>
  </Sidebar>

  <MobileNav items={globalNav} title="Menu" />

  <div class="lg:pl-64 bg-page min-h-screen transition-colors duration-300">
    <main>
      <slot />
    </main>
    <Footer />
  </div>
</BaseLayout>
