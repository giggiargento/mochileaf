---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import MobileNav from '../components/layout/MobileNav.astro';
import Footer from '../components/layout/Footer.astro';
import ThemeToggle from '../components/ui/ThemeToggle.astro';
import AdPlaceholder from '../components/ui/AdPlaceholder.astro';
import { getGameNav } from '../utils/navigation';
import type { Game } from '../types';

interface Props {
  game: Game;
  title: string;
  description?: string;
}

const { game, title, description } = Astro.props;
const navItems = getGameNav(game);
const pageDescription = description ?? game.description;
---

<BaseLayout title={`${game.name} — ${title}`} description={pageDescription} ambient="game">
  <Sidebar
    title={game.name}
    subtitle="Game Hub"
    items={navItems}
    backHref="/"
    backLabel="All games"
  >
    <div slot="footer" class="space-y-4">
      <ThemeToggle />
      <AdPlaceholder slot="sidebar" label="Sidebar ad" />
    </div>
  </Sidebar>

  <MobileNav items={navItems} title={game.name} />

  <div class="lg:pl-64">
    <header class="hidden lg:flex items-center justify-between gap-4 px-8 py-4 border-b border-cream-200/60 dark:border-ink-700/40">
      <div>
        <p class="text-xs font-medium uppercase tracking-widest text-sage-400">{game.tagline}</p>
      </div>
      <ThemeToggle />
    </header>
    <main class="min-h-[60vh]">
      <slot />
    </main>
    <Footer />
  </div>
</BaseLayout>
