---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import AmbientBackground from '../components/layout/AmbientBackground.astro';
import {
  formatTitle,
  getDescription,
  resolveCanonicalUrl,
  resolveOgImageUrl,
  buildWebsiteJsonLd,
  brandAlt,
} from '../utils/seo';
import { brandFavicon } from '../utils/brand';
import {
  getAdSenseClient,
  getAdSenseAllowedHosts,
  allowAdSenseOnLocalhost,
  shouldRenderAdUnits,
} from '../utils/ads';

const adSenseClient = getAdSenseClient();
const adSenseEnabled = shouldRenderAdUnits();
const adSenseHosts = getAdSenseAllowedHosts().join(',');
const adSenseAllowLocal = allowAdSenseOnLocalhost();

interface Props {
  title: string;
  description?: string;
  /** Path (/og.jpg) or absolute URL for social previews. */
  image?: string;
  ambient?: 'home' | 'game' | 'none';
}

const { title, description, image, ambient = 'home' } = Astro.props;
const locale = Astro.currentLocale ?? 'en';
const pageTitle = formatTitle(title);
const pageDescription = getDescription(description);
const canonicalUrl = resolveCanonicalUrl(Astro);
const ogImageUrl = resolveOgImageUrl(Astro, image);
const websiteJsonLd = buildWebsiteJsonLd(Astro);
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION?.trim();
const ogLocale = locale === 'es' ? 'es_ES' : 'en_US';
---

<!doctype html>
<html
  lang={locale}
  data-adsense-client={adSenseEnabled ? adSenseClient : undefined}
  data-adsense-hosts={adSenseEnabled ? adSenseHosts : undefined}
  data-adsense-allow-localhost={adSenseAllowLocal ? 'true' : undefined}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    {
      brandFavicon ? (
        <link
          rel="icon"
          href={brandFavicon}
          type={brandFavicon.endsWith('.svg') ? 'image/svg+xml' : brandFavicon.endsWith('.png') ? 'image/png' : 'image/webp'}
        />
      ) : (
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
      )
    }
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Mochileaf" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={brandAlt} />
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=Nunito:wght@400;500;600;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=Nunito:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <script is:inline>
      (function () {
        var k = 'mochileaf-theme';
        var s = localStorage.getItem(k);
        var d = s === 'dark';
        document.documentElement.classList.toggle('dark', d);
      })();
    </script>
    <script is:inline>
      (function () {
        var k = 'mochileaf-locale';
        if (localStorage.getItem(k) !== 'es') return;
        var p = location.pathname;
        if (p === '/es' || p.indexOf('/es/') === 0) return;
        if (p.indexOf('/_astro') === 0 || p.indexOf('/images') === 0) return;
        if (/\.[a-z0-9]{2,5}$/i.test(p)) return;
        var target = (p === '/' ? '/es' : '/es' + p) + location.search + location.hash;
        location.replace(target);
      })();
    </script>
    <script>
      import '../scripts/theme.client.ts';
      import '../scripts/locale.client.ts';
      import '../scripts/nav.client.ts';
    </script>
    {
      adSenseEnabled && adSenseClient && (
        <script
          is:inline
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adSenseClient}`}
          crossorigin="anonymous"
        />
      )
    }
    {adSenseEnabled && <script src="/scripts/adsense.transitions.js" defer></script>}
    <slot name="head" />
  </head>
  <body class="min-h-screen">
    {
      ambient !== 'none' && (
        <AmbientBackground
          transition:persist={`mochi-ambient-${ambient}`}
          variant={ambient === 'game' ? 'game' : 'home'}
        />
      )
    }
    <slot />
  </body>
</html>
