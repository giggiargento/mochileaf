# Tavily — web search for AI-friendly results (https://tavily.com)
# Free tier available. Used by: npm run content:refresh
TAVILY_API_KEY=

# Optional later: summarize search results into editorial copy
# OPENAI_API_KEY=

# ACNH items catalog — optional; import uses public Nookipedia wiki tables (no key required)
# npm run items:import

# Google AdSense (https://www.google.com/adsense) — after your site is approved
# Publisher ID from AdSense → Account → Account information
PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# Ad unit slot IDs (Ads → By ad unit). Use one DEFAULT for all placeholders, or per placement:
# PUBLIC_ADSENSE_SLOT_DEFAULT=1234567890
# PUBLIC_ADSENSE_SLOT_INLINE=
# PUBLIC_ADSENSE_SLOT_SIDEBAR=
# PUBLIC_ADSENSE_SLOT_FOOTER=
# Also add public/ads.txt with: google.com, pub-XXXXXXXXXXXXXXXX, DIRECT, f08c47fec0942fa0
