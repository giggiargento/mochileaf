# Cozy Creators — Instagram sync (npm run creators:sync)
# Stable: Meta Graph API Business Discovery (your Creator/Business IG linked to a Facebook Page).
# 1) developers.facebook.com → app → Instagram Graph API
# 2) Long-lived Page access token with instagram_basic (+ pages_read_engagement)
# 3) INSTAGRAM_BUSINESS_USER_ID = numeric IG user id of YOUR account (Graph API Explorer: me?fields=id,username)
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_USER_ID=
# Without these, sync uses Instagram’s public web API (often 429 from servers — retry locally).

# Tavily — web search for AI-friendly results (https://tavily.com)
# Free tier available. Used by: npm run content:refresh
TAVILY_API_KEY=

# Optional later: summarize search results into editorial copy
# OPENAI_API_KEY=

# ACNH items catalog — optional; import uses public Nookipedia wiki tables (no key required)
# npm run items:import
# npm run items:optimize-images          # 128px thumb URLs in catalog
# npm run items:optimize-images -- --local  # mirror WebP to public/ (gitignored)
# npm run villagers:optimize-images      # after sync:images for ACNH portraits

# Google AdSense — defaults live in src/data/adsense.ts (override here if needed)
# Ads are OFF during `npm run dev` (no doubleclick 400s on localhost).
# PUBLIC_ADSENSE_CLIENT=ca-pub-5260522875952685
# PUBLIC_ADSENSE_SLOT_INLINE=4007135134
# PUBLIC_ADSENSE_SLOT_SIDEBAR=<second unit id when you create one>
# PUBLIC_ADSENSE_ALLOWED_HOSTS=mochileaf.com,www.mochileaf.com
# PUBLIC_ADSENSE_ALLOW_LOCALHOST=true
# PUBLIC_ADSENSE_TEST=true
# public/ads.txt → google.com, pub-5260522875952685, DIRECT, f08c47fec0942fa0
