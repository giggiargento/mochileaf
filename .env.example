# Tavily — web search for AI-friendly results (https://tavily.com)
# Free tier available. Used by: npm run content:refresh
TAVILY_API_KEY=

# Optional later: summarize search results into editorial copy
# OPENAI_API_KEY=

# ACNH items catalog — optional; import uses public Nookipedia wiki tables (no key required)
# npm run items:import

# Google AdSense — defaults live in src/data/adsense.ts (override here if needed)
# Ads are OFF during `npm run dev` (no doubleclick 400s on localhost).
# PUBLIC_ADSENSE_CLIENT=ca-pub-5260522875952685
# PUBLIC_ADSENSE_SLOT_INLINE=4007135134
# PUBLIC_ADSENSE_SLOT_SIDEBAR=<second unit id when you create one>
# PUBLIC_ADSENSE_ALLOWED_HOSTS=mochileaf.com,www.mochileaf.com
# PUBLIC_ADSENSE_ALLOW_LOCALHOST=true
# public/ads.txt → google.com, pub-5260522875952685, DIRECT, f08c47fec0942fa0
